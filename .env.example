# Notion API
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EVENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BLOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SPEAKERS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ATTENDEES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SPONSORS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TEAM_PROFILES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tools section (staff/contractor-only) — shared HTTP Basic Auth credentials.
# Both username and password must match what the user types into the browser
# prompt. Fails closed if either is unset.
TOOLS_USERNAME=staff
TOOLS_PASSWORD=changeme

# Mailchimp
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-usXX
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxxxx
MAILCHIMP_SERVER_PREFIX=usXX

# Vercel Deploy Hook (used by Slack/Notion triggers)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/xxxxxxxxxxxxx
