# Dependencies
node_modules/

# Build output
dist/
.astro/

# Environment variables
.env
.env.local
.env.production
.env.bak

# Vercel
.vercel/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings (machine-specific permission allowlist)
.claude/settings.local.json

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Playwright MCP scratch
.playwright-mcp/

# Standalone HTML exports — tracked only under share/ (deployed to /share/*).
# Stray copies elsewhere (repo root, work/ client deliverables, etc.) stay ignored.
*-standalone.html
!share/**/*-standalone.html

# Team-member photos generated at build time by scripts/build-team-photos.mjs.
# Notion is the source of truth; every deploy regenerates them.
public/team/

# Per-project Python venvs for one-off WeasyPrint builds (work/<project>/build_pdf.py).
# Self-bootstraps on first run — do not commit.
work/**/.venv-pdf/

# Python bytecode caches (created by work/<project>/build_pdf.py at runtime).
__pycache__/
*.pyc
