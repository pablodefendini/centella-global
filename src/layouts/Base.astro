---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import RandomDisplayAccents from '../components/RandomDisplayAccents.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideChrome?: boolean;
  /**
   * Per-page key color. Tints shared chrome (header logo, menu toggle,
   * nav links, footer logo) and is also exposed to page-local CSS as
   * `var(--page-accent)`. Pass a CSS color or a token reference like
   * `"var(--advisory)"`. Defaults to the principal brand violet.
   */
  pageAccent?: string;
  /**
   * Per-page logo override for header & footer. Path to an SVG in
   * `/public/` (e.g. `/centella-advisory-logo.svg`). All approved
   * lockups share the canonical 1079-unit height of the main divider,
   * so the chrome height stays constant — only the visible logo width
   * changes, derived from `pageLogoWidth`. Defaults to the divider.
   */
  pageLogo?: string;
  /**
   * viewBox width (in user units) of the SVG passed via `pageLogo`.
   * Required when `pageLogo` is set. The main divider is `8694`;
   * sub-brand lockups are `3943`. Height is fixed at 1079 system-wide.
   */
  pageLogoWidth?: number;
}

const {
  title,
  description = 'Centella works with political leaders and movement builders across the Global South.',
  ogImage = '/og-default.png',
  hideChrome = false,
  pageAccent,
  pageLogo,
  pageLogoWidth,
} = Astro.props;

const bodyStyleFragments: string[] = [];
if (pageAccent) bodyStyleFragments.push(`--page-accent: ${pageAccent};`);
if (pageLogo) bodyStyleFragments.push(`--page-logo: url(${pageLogo});`);
if (pageLogoWidth) bodyStyleFragments.push(`--page-logo-width: ${pageLogoWidth};`);
const bodyStyle = bodyStyleFragments.length ? bodyStyleFragments.join(' ') : undefined;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://centellaglobal.com');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Centella</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl.toString()} />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} — Centella`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl.toString()} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Centella`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700;800;900&family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Barlow+Semi+Condensed:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <slot name="head" />
</head>
<body style={bodyStyle}>
  {!hideChrome && <SiteHeader />}
  <main>
    <slot />
  </main>
  {!hideChrome && <SiteFooter />}
  <RandomDisplayAccents />
</body>
</html>
