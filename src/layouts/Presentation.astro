---
interface Props {
  title: string;
  lang?: string;
}
const { title, lang = "en" } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
