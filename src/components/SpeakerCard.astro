---
import type { Speaker } from '../lib/types';

interface Props {
  speaker: Speaker;
}

const { speaker } = Astro.props;
---

<div class="speaker-card">
  {speaker.photo ? (
    <img
      src={speaker.photo}
      alt={speaker.name}
      class="speaker-card__photo"
      loading="lazy"
    />
  ) : (
    <div class="speaker-card__photo speaker-card__photo--placeholder" aria-hidden="true">
      {speaker.name.charAt(0)}
    </div>
  )}
  <h3 class="speaker-card__name">{speaker.name}</h3>
  {speaker.role && <p class="speaker-card__role">{speaker.role}</p>}
  {speaker.title && <p class="speaker-card__title text-muted">{speaker.title}</p>}
  {speaker.organization && <p class="speaker-card__org text-muted">{speaker.organization}</p>}
  {speaker.bio && <p class="speaker-card__bio text-muted">{speaker.bio}</p>}
</div>

<style>
  .speaker-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  .speaker-card__photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-inline: auto;
  }

  .speaker-card__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .speaker-card__name {
    max-width: 28ch;
  }

  .speaker-card__role,
  .speaker-card__title,
  .speaker-card__org,
  .speaker-card__bio {
    max-width: min(100%, var(--prose-max-ch));
    margin: 0;
  }

  /* Role leads (e.g. "Keynote Speaker"); Title and Organization are muted via the
     text-muted utility on the markup. */
  .speaker-card__role {
    font-weight: 500;
  }

  /* Bio sits below the identity block with extra space so it reads as
     biography rather than another tier of the title hierarchy. */
  .speaker-card__bio {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
</style>
