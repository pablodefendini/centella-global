---
import type { Speaker } from '../lib/types';

interface Props {
  speaker: Speaker;
}

const { speaker } = Astro.props;
---

<div class="speaker-card">
  {speaker.photo ? (
    <img
      src={speaker.photo}
      alt={speaker.name}
      class="speaker-card__photo"
      loading="lazy"
    />
  ) : (
    <div class="speaker-card__photo speaker-card__photo--placeholder" aria-hidden="true">
      {speaker.name.charAt(0)}
    </div>
  )}
  <h3 class="speaker-card__name">{speaker.name}</h3>
  {speaker.titleRole && <p class="speaker-card__role text-muted">{speaker.titleRole}</p>}
  {speaker.organization && <p class="speaker-card__org text-muted">{speaker.organization}</p>}
</div>

<style>
  .speaker-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  .speaker-card__photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin-inline: auto;
  }

  .speaker-card__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }

  .speaker-card__name {
    max-width: 28ch;
  }

  .speaker-card__role,
  .speaker-card__org {
    max-width: min(100%, var(--prose-max-ch));
  }
</style>
