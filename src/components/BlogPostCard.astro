---
import type { BlogPost } from '../lib/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<a href={`/blog/${post.slug}/`} class="post-card card">
  {post.heroImage && (
    <img
      src={post.heroImage}
      alt={post.title}
      class="post-card__image"
      loading="lazy"
    />
  )}
  <div class="post-card__body">
    {post.event && (
      <p class="post-card__eyebrow">From {post.event.name}</p>
    )}
    <time class="post-card__date text-muted">{formatDate(post.publishedDate)}</time>
    <h3 class="post-card__title">{post.title}</h3>
    {post.summary && <p class="post-card__summary text-muted">{post.summary}</p>}
  </div>
</a>

<style>
  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card__image {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }

  .post-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .post-card__eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .post-card__date {
    display: block;
  }

  .post-card__title {
  }

  .post-card__summary {
    max-width: min(100%, var(--prose-max-ch));
  }
</style>
