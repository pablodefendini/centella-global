---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
];
---

<nav class="nav" aria-label="Main navigation">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="Centella — home">
      <img src="/logo-divider.svg" alt="Centella" />
    </a>
    <ul class="nav__links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav__link', { 'nav__link--active': currentPath === href }]}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    border-bottom: 1px solid var(--color-border);
    background: rgba(6, 6, 7, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .nav__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    padding-block: var(--space-3);
  }

  .nav__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .nav__logo img {
    height: 24px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .nav__logo:hover { opacity: 0.75; }

  .nav__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-4);
    list-style: none;
    width: 100%;
  }

  @media (min-width: 640px) {
    .nav__inner {
      gap: var(--space-4);
      padding-block: var(--space-4);
    }

    .nav__logo img {
      height: 28px;
    }

    .nav__links { gap: var(--space-4) var(--space-8); }
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    padding: var(--space-2) var(--space-3);
    margin-inline: calc(var(--space-3) * -1);
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    left: var(--space-3);
    bottom: var(--space-2);
    width: 0;
    height: 1.5px;
    background: var(--accent-purple);
    transition: width 0.3s var(--ease);
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-text);
  }

  .nav__link:hover::after,
  .nav__link--active::after {
    width: calc(100% - 2 * var(--space-3));
  }
</style>
