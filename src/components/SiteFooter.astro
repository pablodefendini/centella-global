---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/centella-advisory/', label: 'Centella Advisory' },
  { href: '/centella-institute/', label: 'Centella Institute events' },
  { href: '/centella-impact/', label: 'Centella Impact' },
  { href: '/blog/', label: 'Blog' },
  { href: '/styleguide/', label: 'Styleguide' },
] as const;
---

<footer class="site-footer">
  <div class="site-footer__logo-wrap">
    <img
      src="/logo-divider.svg"
      alt=""
      width="8694"
      height="1079"
      class="site-footer__logo-divider"
      decoding="async"
    />
  </div>
  <nav class="site-footer__nav" aria-label="Footer">
    <ul class="site-footer__list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="site-footer__link">{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</footer>

<style>
  .site-footer {
    padding: var(--space-6) var(--gutter);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .site-footer__logo-wrap {
    margin-bottom: var(--space-6);
    overflow: hidden;
  }

  .site-footer__logo-divider {
    display: block;
    width: 100vw;
    max-width: none;
    margin-inline: calc(50% - 50vw);
    height: auto;
    opacity: 0.9;
    filter: brightness(0) invert(1) brightness(1.35) contrast(1.12);
  }

  .site-footer__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: 0;
  }

  .site-footer__link {
    color: var(--color-text-dim);
    text-decoration: none;
    min-height: var(--touch-target-min);
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--color-text);
    outline: none;
  }
</style>
