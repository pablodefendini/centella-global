---
import type { Event } from '../lib/types';

interface Props {
  event: Event;
}

const { event } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<a href={`/events/${event.slug}/`} class="event-card card">
  {event.heroImage && (
    <img
      src={event.heroImage}
      alt={event.name}
      class="event-card__image"
      loading="lazy"
    />
  )}
  <div class="event-card__body">
    <time class="event-card__date text-muted">{formatDate(event.dateStart)}</time>
    <h3 class="event-card__title">{event.name}</h3>
    {event.tagline && <p class="event-card__tagline text-muted">{event.tagline}</p>}
    {event.location && <p class="event-card__location text-muted">{event.location}</p>}
  </div>
</a>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .event-card__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }

  .event-card:hover .event-card__image {
    transform: scale(1.04);
  }

  .event-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .event-card__date {
    display: block;
    color: var(--accent-teal);
  }

  .event-card__title {
    color: var(--color-text);
  }

  .event-card__tagline {
    color: var(--color-text-muted);
    max-width: min(100%, var(--prose-max-ch));
  }

  .event-card__location {
    color: var(--color-text-dim);
  }
</style>
