---
/**
 * Inline SVG icon that respects currentColor.
 * Drop any SVG into src/assets/icons/ — its filename (without extension) is the `name`.
 *
 * Props:
 *   name   — required; filename without `.svg` (e.g. "Checkmark", "Money Bag")
 *   size   — width/height in px (number) or any CSS length (string). Default 24.
 *   label  — accessible label; if omitted the icon is hidden from assistive tech.
 *   class  — passthrough class for layout / positioning.
 */
interface Props {
  name: string;
  size?: number | string;
  label?: string;
  class?: string;
}

const { name, size = 24, label, class: className } = Astro.props;

const files = import.meta.glob<string>('../assets/icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const match = Object.entries(files).find(([path]) =>
  path.endsWith(`/${name}.svg`)
);

if (!match) {
  throw new Error(
    `[Icon] No icon found for name "${name}". Check src/assets/icons/ for available files.`
  );
}

// Strip hard-coded width/height so CSS controls size.
const raw = match[1]
  .replace(/\swidth="[^"]*"/i, '')
  .replace(/\sheight="[^"]*"/i, '');

const dim = typeof size === 'number' ? `${size}px` : size;
---

<span
  class:list={['icon', className]}
  style={`--icon-size: ${dim};`}
  role={label ? 'img' : 'presentation'}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={raw}
/>

<style>
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-size);
    height: var(--icon-size);
    color: currentColor;
    flex-shrink: 0;
  }
  .icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
</content>
</invoke>