---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';

// All icons in src/assets/icons/, sorted case-insensitively by name.
const iconFiles = import.meta.glob<string>('../assets/icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const iconNames = Object.keys(iconFiles)
  .map((p) => p.split('/').pop()!.replace('.svg', ''))
  .sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));

const brandAttributes = [
  'Strategic and long-term oriented, not reactive or trend-driven',
  'Global in outlook, but grounded in lived realities and material conditions',
  'Serious about power and systems, without visual austerity or dryness',
  'Optimistic and future-facing, while remaining politically lucid',
];

const voiceIs = ['Confident, never arrogant', 'Provocative, never cynical', 'Inspiring, never naïve', 'Clear, never wonky'];
const voiceIsMore = ['Strategist than commentator', 'Facilitator than lecturer', 'Builder than critic', 'Global without being generic', 'Political without shallow partisanship'];
const voiceIsNot = ['A distant academic voice', 'A performative NGO', 'An expensive but hollow consultancy', 'A bureaucratic network', 'A platform for pretty progressive speeches without consequence'];
const wordsAvoid = ['Wonky', 'Preachy', 'Traditional', 'Aloof', 'Vague', 'Inspirational-only'];
const wordsFit = ['Power', 'Strategy', 'Win', 'Build', 'Shift', 'Deliver', 'Train', 'Scale', 'Rooted', 'Ethical', 'Global South'];

const colorFamilies = [
  { key: 'violet', label: 'Centella Violet', role: 'Principal brand — synthesis, depth, ethical seriousness', primary: '#C77DFF', dark: '#1E1A28', light: '#F7EDFF' },
  { key: 'advisory', label: 'Advisory Blue', role: 'Strategy & guidance — trust, stability, precision', primary: '#00E5FF', dark: '#0E2228', light: '#E1FCFF' },
  { key: 'networking', label: 'Networking Red', role: 'Mobilization & power — urgency, connection', primary: '#FF6B6B', dark: '#22181C', light: '#FFE8E8' },
  { key: 'investment', label: 'Investment Green', role: 'Capital & impact — growth, long-term sustainability', primary: '#CCFF00', dark: '#1E2413', light: '#FAFFE6' },
  { key: 'global', label: 'Global Orange', role: 'Scale & reach — expansion, cross-border connection', primary: '#FF9500', dark: '#301C00', light: '#FFF3E1' },
  { key: 'tech', label: 'Tech Pink', role: 'Innovation & experimentation — used sparingly', primary: '#FF66C4', dark: '#2A1522', light: '#FFE6F5' },
];

const typeScale = [
  { token: '--text-6xl', size: '4.507rem', sample: 'Theory in motion' },
  { token: '--text-5xl', size: '3.634rem', sample: 'Theory in motion' },
  { token: '--text-4xl', size: '2.931rem', sample: 'Theory in motion' },
  { token: '--text-3xl', size: '2.364rem', sample: 'Theory in motion' },
  { token: '--text-2xl', size: '1.907rem', sample: 'Theory in motion' },
  { token: '--text-xl', size: '1.538rem', sample: 'Theory in motion' },
  { token: '--text-lg', size: '1.24rem', sample: 'Theory in motion' },
  { token: '--text-base', size: '1rem', sample: 'Theory in motion' },
  { token: '--text-sm', size: '0.806rem', sample: 'Theory in motion' },
  { token: '--text-xs', size: '0.65rem', sample: 'Theory in motion' },
];

const spacing = [
  { token: '--space-1', px: '4px' },
  { token: '--space-2', px: '8px' },
  { token: '--space-3', px: '12px' },
  { token: '--space-4', px: '16px' },
  { token: '--space-6', px: '24px' },
  { token: '--space-8', px: '32px' },
  { token: '--space-12', px: '48px' },
  { token: '--space-16', px: '64px' },
  { token: '--space-24', px: '96px' },
];

const gradients = [
  { name: 'violet → coral', css: 'linear-gradient(135deg, #C77DFF, #FF6B6B)' },
  { name: 'cyan → lime', css: 'linear-gradient(135deg, #00E5FF, #CCFF00)' },
  { name: 'coral → orange', css: 'linear-gradient(135deg, #FF6B6B, #FF9500)' },
  { name: 'pink → violet', css: 'linear-gradient(135deg, #FF66C4, #C77DFF)' },
  { name: 'cyan → violet', css: 'linear-gradient(135deg, #00E5FF, #C77DFF)' },
];

const subbrands = [
  { name: 'Centella Global Advisory', accent: 'advisory', logo: '/centella-logo.svg', desc: 'Rigorous, strategic; credible in high-stakes environments. Calm, serious, precise.' },
  { name: 'Centella Institute', accent: 'networking', logo: '/centella-logo.svg', desc: 'Energetic, convening-oriented, pedagogical and participatory. Most flexible of the sub-brands.' },
  { name: 'Centella Impact', accent: 'investment', logo: '/centella-logo.svg', desc: 'Serious, disciplined, systems-oriented. Trustworthy to partners and investors.' },
];
---

<Base title="Design System">
  <div class="styleguide container">
    <header class="sg-hero">
      <p class="sg-eyebrow">v0.1 · Design System</p>
      <h1>Design System</h1>
      <p class="sg-lede">
        A living reference, structured from the <em>Centella Brand Guidelines v1.0</em>.
        Every token shown here is wired to <code>src/styles/global.css</code>. The guide
        is not a collection of assets to copy and paste — it is a framework for making
        deliberate visual decisions.
      </p>
    </header>

    <!-- ── 1. Brand Essence ─────────────────────────── -->
    <section id="essence" class="sg-section">
      <div class="sg-section-head">
        <h2>Brand Essence & Positioning</h2>
      </div>
      <p class="sg-paragraph">
        Centella operates at the intersection of politics, technology, organizing, and
        ideas. The brand communicates <strong>intellectual seriousness without rigidity</strong>,
        optimism without cutesy naïveté, and global ambition without abstraction.
      </p>
      <p class="sg-paragraph">
        Centella is not a consultancy in the conventional sense, nor a think tank in
        the academic mold. It is <em>an applied ideas platform: theory in motion</em>.
        The visual and verbal identity is confident and contemporary, editorial rather
        than corporate, principled rather than decorative.
      </p>

      <h3>Key brand attributes</h3>
      <ul class="sg-list">
        {brandAttributes.map((a) => <li>{a}</li>)}
      </ul>

      <aside class="sg-callout">
        The Centella brand should always feel intentional. Nothing is ornamental or
        by accident; nothing is casual by default.
      </aside>
    </section>

    <!-- ── 2. Voice & Tone ──────────────────────────── -->
    <section id="voice" class="sg-section">
      <div class="sg-section-head">
        <h2>Voice & Tone</h2>
      </div>
      <p class="sg-paragraph">
        Confidence comes from experience, not bravado. Provocation comes from clarity,
        not outrage. This is the voice of people who have tried, failed, learned, and
        returned sharper.
      </p>

      <div class="sg-voice-grid">
        <div class="sg-voice-card">
          <div class="sg-voice-label" style="color: var(--advisory);">Centella's Tone Is</div>
          <ul class="sg-list">{voiceIs.map((v) => <li>{v}</li>)}</ul>
        </div>
        <div class="sg-voice-card">
          <div class="sg-voice-label" style="color: var(--investment);">Centella Is More…</div>
          <ul class="sg-list">{voiceIsMore.map((v) => <li>{v}</li>)}</ul>
        </div>
        <div class="sg-voice-card">
          <div class="sg-voice-label" style="color: var(--networking);">Centella Is Not</div>
          <ul class="sg-list">{voiceIsNot.map((v) => <li>{v}</li>)}</ul>
        </div>
      </div>

      <h3 style="margin-top: var(--space-12);">Words that fit — and words to avoid</h3>
      <div class="sg-word-grid">
        <div class="sg-word-col">
          <div class="sg-voice-label" style="color: var(--investment);">Use deliberately</div>
          <div class="sg-chips">
            {wordsFit.map((w) => <span class="sg-chip sg-chip--good">{w}</span>)}
          </div>
        </div>
        <div class="sg-word-col">
          <div class="sg-voice-label" style="color: var(--networking);">Avoid</div>
          <div class="sg-chips">
            {wordsAvoid.map((w) => <span class="sg-chip sg-chip--bad">{w}</span>)}
          </div>
        </div>
      </div>

      <h3 style="margin-top: var(--space-12);">Quick voice test</h3>
      <p class="sg-paragraph">Before publishing, ask:</p>
      <ol class="sg-list sg-list--ordered">
        <li>Does this point to a real power problem?</li>
        <li>Is it clear who gains what?</li>
        <li>Does it show how something changes in practice?</li>
        <li>Would this sound honest if said in a closed room, not just on a website?</li>
      </ol>
    </section>

    <!-- ── 3. Logo ──────────────────────────────────── -->
    <section id="logo" class="sg-section">
      <div class="sg-section-head">
        <h2>Logo & Wordmark</h2>
      </div>
      <p class="sg-paragraph">
        The Spark Logo and the wordmark form the <strong>Logo Lockup</strong> — the
        authoritative mark for the Centella brand, and the structural foundation of
        the visual system. The two share a common <em>horizon</em>; that horizon can
        extend outward as a rule or divider across layouts.
      </p>

      <div class="sg-logo-demo">
        <div class="sg-logo-stage sg-logo-stage--dark">
          <img src="/centella-logo.svg" alt="Centella lockup on dark" />
          <span class="sg-stage-label">On dark</span>
        </div>
        <div class="sg-logo-stage sg-logo-stage--light">
          <img src="/centella-logo.svg" alt="Centella lockup on light" class="sg-logo-invert" />
          <span class="sg-stage-label">On light</span>
        </div>
      </div>

      <div class="sg-do-dont">
        <div class="sg-do-dont-col">
          <div class="sg-voice-label" style="color: var(--investment);">Do</div>
          <ul class="sg-list">
            <li>Use the full lockup in formal applications</li>
            <li>Preserve proportions and spacing exactly</li>
            <li>Use light lockup on dark, saturated, or photographic backgrounds</li>
            <li>Respect minimums — 25 mm print, 120 px digital</li>
          </ul>
        </div>
        <div class="sg-do-dont-col">
          <div class="sg-voice-label" style="color: var(--networking);">Don't</div>
          <ul class="sg-list">
            <li>Separate the Spark from the wordmark</li>
            <li>Recolor outside the approved palette</li>
            <li>Rotate, skew, or distort the lockup</li>
            <li>Add shadows, glows, gradients, or textures</li>
            <li>Place the lockup on visually noisy or low-contrast backgrounds</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── 4. Typography ────────────────────────────── -->
    <section id="type" class="sg-section">
      <div class="sg-section-head">
        <h2>Typography</h2>
      </div>
      <p class="sg-paragraph">
        Barlow is Centella's core typeface — a contemporary grotesk with industrial
        roots. Its functional clarity and public-facing DNA align with Centella's
        commitment to precision, legibility, and accountability.
        <strong>Barlow Condensed</strong> is the default voice: focused, urgent, efficient.
      </p>

      <div class="sg-fonts">
        <article class="sg-font">
          <div class="sg-font-label" style="color: var(--violet);">Display · Default Voice</div>
          <div class="sg-font-name">Barlow Condensed</div>
          <p class="sg-muted">Headlines, display, section headers, program names, posters, event materials.</p>
          <div class="sg-font-sample">We re-energize movements.</div>
        </article>

        <article class="sg-font">
          <div class="sg-font-label" style="color: var(--advisory);">Heading & Sub-Headline</div>
          <div class="sg-font-name">Barlow Regular</div>
          <p class="sg-muted">Card titles, sub-headlines, where comfort matters more than punch.</p>
          <div class="sg-font-sample">Building networks across borders.</div>
        </article>

        <article class="sg-font">
          <div class="sg-font-label" style="color: var(--global);">Labels · UI · Navigation</div>
          <div class="sg-font-name">Barlow Semi Condensed</div>
          <p class="sg-muted">Uppercase eyebrows, nav, buttons, ticker. Always tracked out.</p>
          <div class="sg-font-sample sg-eyebrow">DEMOCRATIC RENEWAL · BANGKOK 2026</div>
        </article>

        <article class="sg-font">
          <div class="sg-font-label" style="color: var(--investment);">Body · Interface</div>
          <div class="sg-font-name">Barlow</div>
          <p class="sg-muted">Paragraphs, form fields, interface copy, long-form reading. Set at regular width for comfort and endurance.</p>
          <div class="sg-font-sample">Centella answers the call to re-energize movements, restore citizen power, and build the next generation of democratic leaders.</div>
        </article>
      </div>

      <aside class="sg-callout" style="margin-top: var(--space-12);">
        <strong>One family, many voices.</strong> The Barlow superfamily does all the
        work — Condensed for action and display, Regular for headings and body,
        Semi Condensed for labels and UI. Discipline inside one family reinforces
        authority more than reaching for a second typeface ever could.
      </aside>

      <h3 style="margin-top: var(--space-12);">Type Scale</h3>
      <p class="sg-muted">Reference table from a 1rem base using the 1.24 modular ratio.</p>
      <div class="sg-table-wrap">
        <table class="sg-table">
          <thead>
            <tr>
              <th>Token</th>
              <th>1.24 ratio value</th>
              <th>1.24 visual sample</th>
            </tr>
          </thead>
          <tbody>
            {typeScale.map((row) => (
              <tr>
                <td><code class="sg-code">{row.token}</code></td>
                <td>{row.size}</td>
                <td class="sg-table-sample-cell">
                  <span class="sg-table-sample" style={`font-size: ${row.size};`}>{row.sample}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 style="margin-top: var(--space-12);">Display type</h3>
      <p class="sg-muted">
        Barlow Condensed, <strong>300 light</strong> base with an <strong>800 extrabold</strong> accent phrase
        clipped to an <strong>approved brand gradient</strong> (default <code>--grad-violet-coral</code>, or one of the
        <code>.display__accent--*</code> modifiers). Add <code>data-random-accent-gradient</code> on each accent span
        for a random gradient on every page load. The 300 ↔ 800 contrast is the signature.
      </p>
      <p class="display" style="margin: var(--space-6) 0 var(--space-2);">
        <span class="display__accent" data-random-accent-gradient>Power. Strategy.</span> Win.
      </p>
      <p class="sg-muted" style="font-family: var(--font-mono); font-size: var(--text-xs);">
        <code>&lt;h1 class="display"&gt;&lt;span class="display__accent" data-random-accent-gradient&gt;…&lt;/span&gt; …&lt;/h1&gt;</code>
      </p>
      <p class="sg-muted" style="margin-top: var(--space-4);">
        Explicit classes (no script):
        <code>display__accent--violet-coral</code>, <code>display__accent--cyan-lime</code>,
        <code>display__accent--coral-orange</code>, <code>display__accent--pink-violet</code>,
        <code>display__accent--cyan-violet</code>, <code>display__accent--lime-teal</code>
        (each paired with <code>display__accent</code>).
      </p>

      <h3 style="margin-top: var(--space-12);">Other approved gradients</h3>
      <p class="sg-muted">
        Same tokens as surfaces, borders, and UI accents — also mapped to display accent classes above. Never apply
        gradients to the logo.
      </p>
      <div class="sg-grad-demo">
        <span style="background: linear-gradient(135deg, var(--violet), var(--networking));">re-energize</span>
        <span style="background: linear-gradient(135deg, var(--advisory), var(--investment));">citizen power</span>
        <span style="background: linear-gradient(135deg, var(--advisory), var(--violet));">democratic leaders</span>
      </div>
    </section>

    <!-- ── 5. Color System ──────────────────────────── -->
    <section id="color" class="sg-section">
      <div class="sg-section-head">
        <h2>Color System</h2>
      </div>
      <p class="sg-paragraph">
        Colors are organized into <strong>functional families</strong>, not arbitrary
        swatches. Each family includes a primary, dark, and light variant. Deep tones
        establish credibility; bright hues introduce urgency and momentum.
      </p>

      <div class="sg-families">
        {colorFamilies.map((f) => (
          <article class="sg-family">
            <header class="sg-family-head">
              <h3 style={`color: ${f.primary};`}>{f.label}</h3>
              <p class="sg-muted">{f.role}</p>
            </header>
            <div class="sg-family-swatches">
              <div class="sg-fs">
                <div class="sg-fs-chip" style={`background: ${f.primary};`}></div>
                <div class="sg-fs-meta">
                  <code class="sg-code">--{f.key}</code>
                  <span class="sg-muted">{f.primary}</span>
                  <span class="sg-fs-role">Primary</span>
                </div>
              </div>
              <div class="sg-fs">
                <div class="sg-fs-chip" style={`background: ${f.dark};`}></div>
                <div class="sg-fs-meta">
                  <code class="sg-code">--{f.key}-dark</code>
                  <span class="sg-muted">{f.dark}</span>
                  <span class="sg-fs-role">Authority · gravity</span>
                </div>
              </div>
              <div class="sg-fs">
                <div class="sg-fs-chip" style={`background: ${f.light}; border-color: rgba(0,0,0,0.15);`}></div>
                <div class="sg-fs-meta">
                  <code class="sg-code">--{f.key}-light</code>
                  <span class="sg-muted">{f.light}</span>
                  <span class="sg-fs-role">Openness · space</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <h3 style="margin-top: var(--space-12);">System rules</h3>
      <ul class="sg-list">
        <li>Do not mix more than two color families in a single composition</li>
        <li>Use dark variants for authority, light variants for space</li>
        <li>Avoid treating all colors as equal — hierarchy matters</li>
        <li>Color should support meaning, not replace it</li>
        <li>Inline-link hover/focus states should always use a contrasting tone relative to base link color</li>
        <li>Links inside tone-coded surfaces like panels should inherit tone and keep contrasting tone-based hover/focus states</li>
      </ul>
      <p class="sg-muted">
        Implementation note: use the shared inline-link token pattern (<code class="sg-code">--inline-link-color</code>,
        <code class="sg-code">--inline-link-hover-color</code>) so hover/focus always resolve to a
        contrasting tone. For tone-coded surfaces, apply <code class="sg-code">.tone-surface</code> and
        set base link color with <code class="sg-code">currentColor</code>.
      </p>
      <p class="sg-muted">
        Rationale: tone-consistent links strengthen information scent and reduce visual contradiction.
        When link color matches the surface context, actions read as part of that context rather than as
        generic global UI accents.
      </p>

      <h3 style="margin-top: var(--space-12);">Gradients</h3>
      <p class="sg-muted">Permitted as a web-only expression — never on the logo lockup.</p>
      <div class="sg-gradients">
        {gradients.map((g) => (
          <div class="sg-gradient">
            <div class="sg-gradient-chip" style={`background: ${g.css};`}></div>
            <div class="sg-gradient-meta">
              <span class="sg-gradient-name">{g.name}</span>
              <code class="sg-code">{g.css}</code>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── 6. Color Scale Generator ─────────────────── -->
    <section id="generator" class="sg-section">
      <div class="sg-section-head">
        <h2>Color Scale Generator</h2>
      </div>
      <p class="sg-paragraph">
        Extend the system for campaigns, sub-brands, or new contexts. Enter any base
        color — the tool generates primary, alternate, dark, and light variants using
        the same tonal logic that produced the core families above.
      </p>

      <div class="csg" id="csg">
        <div class="csg-controls">
          <label class="csg-control">
            <span class="sg-voice-label">Base color</span>
            <div class="csg-input-row">
              <input type="color" id="csg-picker" value="#C77DFF" aria-label="Base color picker" />
              <input type="text" id="csg-hex" value="#C77DFF" maxlength="7" aria-label="Base color hex" />
            </div>
          </label>
          <label class="csg-control">
            <span class="sg-voice-label">Name <span class="sg-muted">(optional)</span></span>
            <input type="text" id="csg-name" placeholder="e.g. Campaign Teal" class="csg-name-input" />
          </label>
          <div class="csg-presets">
            <span class="sg-voice-label">Quick start</span>
            <div class="csg-preset-row">
              <button type="button" data-hex="#C77DFF" data-name="Centella Violet" style="background: #C77DFF;"></button>
              <button type="button" data-hex="#00E5FF" data-name="Advisory Blue" style="background: #00E5FF;"></button>
              <button type="button" data-hex="#FF6B6B" data-name="Networking Red" style="background: #FF6B6B;"></button>
              <button type="button" data-hex="#CCFF00" data-name="Investment Green" style="background: #CCFF00;"></button>
              <button type="button" data-hex="#FF9500" data-name="Global Orange" style="background: #FF9500;"></button>
              <button type="button" data-hex="#FF66C4" data-name="Tech Pink" style="background: #FF66C4;"></button>
            </div>
          </div>
        </div>

        <div class="csg-output" id="csg-output">
          <!-- swatches injected by script -->
        </div>

        <details class="csg-css">
          <summary>Copy as CSS custom properties</summary>
          <pre><code id="csg-css-out"></code></pre>
        </details>
      </div>
    </section>

    <!-- ── 7. Visual Language ───────────────────────── -->
    <section id="visual" class="sg-section">
      <div class="sg-section-head">
        <h2>Visual Language</h2>
      </div>
      <p class="sg-paragraph">
        Architectural and assertive. Built from a small set of strong structural
        ideas — <em>axes, horizons, diagonals, and panels</em> — recombined into
        flexible but unmistakable compositions. The goal is not visual softness;
        the goal is <strong>clarity under pressure</strong>.
      </p>

      <h3>Structural axes</h3>
      <p class="sg-muted">
        The Centella logo determines axis points at 0°, 90°, 120°, and 150°. These
        axes align type, anchor layouts, and act as directional separators.
      </p>
      <div class="sg-axes-demo">
        <div class="sg-axes-inner">
          <div class="sg-axis sg-axis--0"></div>
          <div class="sg-axis sg-axis--90"></div>
          <div class="sg-axis sg-axis--120"></div>
          <div class="sg-axis sg-axis--150"></div>
          <span class="sg-axes-label">0° · 90° · 120° · 150°</span>
        </div>
      </div>

      <h3 style="margin-top: var(--space-12);">Colored panels</h3>
      <p class="sg-muted">
        Color is deployed through bold panels — not soft backgrounds. Hard edges preferred,
        but always a corner radius of <code class="sg-code">4px</code>,
        <code class="sg-code">8px</code>, or <code class="sg-code">16px</code>. Each
        panel sits in space with an inner frame aligned to the underlying grid.
      </p>
      <p class="sg-muted">
        Panels are tone-coded surfaces: text and links inside them should inherit
        panel tone so actions remain contextually coherent.
      </p>
      <div class="sg-panel-demo">
        <div class="sg-panel" style="background: var(--violet); color: var(--violet-dark); border-radius: 4px;">
          <div class="sg-panel-frame" style="border-color: rgba(30,26,40,0.3);">
            <div class="sg-voice-label" style="color: var(--violet-dark); opacity: 0.7;">Radius 4px</div>
            <p style="color: var(--violet-dark); margin: 0;">Theory in motion.</p>
          </div>
        </div>
        <div class="sg-panel" style="background: var(--advisory-dark); color: var(--advisory); border-radius: 8px;">
          <div class="sg-panel-frame" style="border-color: rgba(0,229,255,0.3);">
