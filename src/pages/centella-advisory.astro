---
import Base from '../layouts/Base.astro';
---

<Base
  title="Centella Advisory"
  description="We support leaders with hands-on coaching and strategy development to help them win campaigns and deliver lasting change."
  pageAccent="var(--advisory)"
  pageLogo="/centella-advisory-logo.svg"
  pageLogoWidth={3943}
>
  <section class="section">
    <div class="container page-simple">
      <h1 class="page-heading">Advising leaders</h1>
      <p class="page-copy">
        We support leaders with hands-on coaching and strategy development to help them win campaigns and deliver lasting change.
      </p>
    </div>
  </section>
</Base>
