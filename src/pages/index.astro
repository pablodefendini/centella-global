---
import Base from '../layouts/Base.astro';
import { getHomepageLatestEvent } from '../lib/notion';

const latestEvent = await getHomepageLatestEvent();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
] as const;
---

<Base title="Home" hideChrome={true}>
  <div class="home-min">
    <header class="home-min__header">
      <a href="/" class="home-min__logo" aria-label="Centella — home">
        <img src="/logo.svg" alt="Centella" width="120" height="28" />
      </a>
      <nav class="home-min__nav" aria-label="Main">
        <ul class="home-min__nav-list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="home-min__nav-link">{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <div class="home-min__main">
      <section class="home-min__hero" aria-labelledby="home-hero-heading">
        <h1 id="home-hero-heading" class="home-min__headline">
          We re-energize movements,<br />
          restore citizen power, and build the next generation of democratic leaders
        </h1>
      </section>

      {latestEvent && (
        <section class="home-min__event" aria-labelledby="home-event-heading">
          <h2 id="home-event-heading" class="home-min__event-label">Latest event</h2>
          <a href={`/events/${latestEvent.slug}/`} class="home-min__event-link">
            {latestEvent.name}
          </a>
        </section>
      )}
    </div>

    <footer class="home-min__footer">
      <nav class="home-min__footer-nav" aria-label="Footer">
        <ul class="home-min__footer-list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="home-min__footer-link">{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </footer>
  </div>
</Base>

<style>
  .home-min {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .home-min__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6) var(--gutter);
    border-bottom: 1px solid var(--color-border);
  }

  .home-min__logo {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }

  .home-min__logo img {
    height: 28px;
    width: auto;
    max-width: 120px;
    filter: brightness(0) invert(1);
  }

  .home-min__nav-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: 0;
  }

  .home-min__nav-link,
  .home-min__footer-link {
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    padding: var(--space-2) var(--space-2);
    margin-inline: calc(var(--space-2) * -1);
    transition: color var(--transition-fast);
  }

  .home-min__nav-link:hover,
  .home-min__nav-link:focus-visible,
  .home-min__footer-link:hover,
  .home-min__footer-link:focus-visible {
    color: var(--color-text);
  }

  .home-min__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: var(--space-12) var(--gutter) var(--space-16);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .home-min__hero {
    flex: 1;
    display: flex;
    align-items: center;
  }

  .home-min__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: min(100%, var(--prose-max-ch));
    margin: 0;
  }

  .home-min__event {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .home-min__event-label {
    font-family: var(--font-semi);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin: 0;
  }

  .home-min__event-link {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent-purple);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    max-width: min(100%, var(--prose-max-ch));
    transition: color var(--transition-fast);
  }

  .home-min__event-link:hover,
  .home-min__event-link:focus-visible {
    color: var(--accent-coral);
  }

  .home-min__footer {
    padding: var(--space-6) var(--gutter);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .home-min__footer-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .home-min__header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    .home-min__logo img {
      height: 32px;
    }

  }
</style>
