---
import Base from '../layouts/Base.astro';
import { getHomepageLatestEvent } from '../lib/notion';

const latestEvent = await getHomepageLatestEvent();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/events/', label: 'Events' },
  { href: '/blog/', label: 'Blog' },
] as const;

const heroPoster = '/media/hero/centella-hero-bg-poster.webp';
const heroVideo720 = '/media/hero/centella-hero-bg-720.mp4';
const heroVideo540 = '/media/hero/centella-hero-bg-540.mp4';
---

<Base title="Home" hideChrome={true}>
  <div class="home-min">
    <header class="home-min__header">
      <div class="home-min__header-bar">
        <button
          type="button"
          id="home-min-menu-toggle"
          class="home-min__menu-toggle"
          aria-expanded="false"
          aria-controls="home-min-menu"
          aria-label="Open menu"
        >
          <span class="home-min__menu-icon" aria-hidden="true">
            <span class="home-min__menu-line"></span>
            <span class="home-min__menu-line"></span>
            <span class="home-min__menu-line"></span>
          </span>
        </button>
      </div>
      <a href="/" class="home-min__logo" aria-label="Centella — home">
        <img
          src="/logo.svg"
          alt=""
          width="8694"
          height="1079"
          class="home-min__logo-img"
          decoding="async"
        />
      </a>
      <div id="home-min-menu" class="home-min__menu" hidden role="dialog" aria-modal="true" aria-label="Site navigation">
        <div class="home-min__menu-panel">
          <button type="button" class="home-min__menu-close" aria-label="Close menu">Close</button>
          <nav class="home-min__menu-nav" aria-label="Main">
            <ul class="home-min__menu-list">
              {navLinks.map(({ href, label }) => (
                <li>
                  <a href={href} class="home-min__nav-link home-min__menu-link">{label}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <script is:inline>
      (function () {
        var toggle = document.getElementById('home-min-menu-toggle');
        var menu = document.getElementById('home-min-menu');
        if (!toggle || !menu) return;
        var closeBtn = menu.querySelector('.home-min__menu-close');

        function setOpen(open) {
          menu.hidden = !open;
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          document.body.style.overflow = open ? 'hidden' : '';
        }

        function isOpen() {
          return !menu.hidden;
        }

        toggle.addEventListener('click', function () {
          setOpen(!isOpen());
        });
        if (closeBtn) {
          closeBtn.addEventListener('click', function () {
            setOpen(false);
            toggle.focus();
          });
        }
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && isOpen()) {
            setOpen(false);
            toggle.focus();
          }
        });
        menu.addEventListener('click', function (e) {
          if (e.target === menu) setOpen(false);
        });
      })();
    </script>

    <section class="home-min__hero" aria-labelledby="home-hero-heading">
      <div class="home-min__hero-media" aria-hidden="true">
        <img
          class="home-min__hero-poster"
          src={heroPoster}
          alt=""
          width="1600"
          height="800"
          fetchpriority="high"
          decoding="async"
        />
        <video
          id="home-hero-video"
          class="home-min__hero-video"
          muted
          loop
          playsinline
          preload="none"
          poster={heroPoster}
        />
        <div class="home-min__hero-scrim"></div>
      </div>
      <div class="home-min__hero-inner">
        <h1 id="home-hero-heading" class="home-min__headline">
          We re-energize movements,<br />
          restore citizen power, and build the next generation of democratic leaders
        </h1>
      </div>
    </section>

    <script is:inline define:vars={{ heroVideo720, heroVideo540 }}>
      (function () {
        var video = document.getElementById('home-hero-video');
        if (!video) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        if (conn) {
          if (conn.saveData) return;
          var t = conn.effectiveType;
          if (t === 'slow-2g' || t === '2g' || t === '3g') return;
        }

        var narrow = window.matchMedia('(max-width: 639px)').matches;
        video.src = narrow ? heroVideo540 : heroVideo720;
        video.load();
        var p = video.play();
        if (p && typeof p.catch === 'function') p.catch(function () {});
      })();
    </script>

    <div class="home-min__main">
      {latestEvent && (
        <section class="home-min__event" aria-labelledby="home-event-heading">
          <h2 id="home-event-heading" class="home-min__event-label">Latest event</h2>
          <a href={`/events/${latestEvent.slug}/`} class="home-min__event-link">
            {latestEvent.name}
          </a>
        </section>
      )}
    </div>

    <footer class="home-min__footer">
      <nav class="home-min__footer-nav" aria-label="Footer">
        <ul class="home-min__footer-list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="home-min__footer-link">{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </footer>
  </div>
</Base>

<style>
  .home-min {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    color: var(--color-text);
    overflow-x: clip;
  }

  .home-min__header {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .home-min__header-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: var(--space-3) var(--gutter);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: relative;
    z-index: 2;
  }

  .home-min__menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--touch-target-min);
    min-height: var(--touch-target-min);
    padding: var(--space-2);
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg-alt);
    color: var(--color-text);
    cursor: pointer;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .home-min__menu-toggle:hover,
  .home-min__menu-toggle:focus-visible {
    border-color: var(--color-text-muted);
    color: var(--color-text);
    background: var(--color-bg-elevated);
    outline: none;
  }

  .home-min__menu-toggle:focus-visible {
    box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 4px var(--accent-purple);
  }

  .home-min__menu-toggle[aria-expanded='true'] {
    position: fixed;
    top: var(--space-3);
    right: var(--gutter);
    z-index: 201;
  }

  .home-min__menu-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 1.25rem;
    height: 1rem;
  }

  .home-min__menu-line {
    display: block;
    height: 2px;
    width: 100%;
    background: currentColor;
    border-radius: 1px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .home-min__menu-toggle[aria-expanded='true'] .home-min__menu-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .home-min__menu-toggle[aria-expanded='true'] .home-min__menu-line:nth-child(2) {
    opacity: 0;
  }

  .home-min__menu-toggle[aria-expanded='true'] .home-min__menu-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-min__menu-line {
      transition: none;
    }
  }

  .home-min__logo {
    display: block;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    line-height: 0;
    background: var(--color-bg);
  }

  .home-min__logo-img {
    display: block;
    width: 100%;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .home-min__menu {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    padding: calc(var(--touch-target-min) + var(--space-6)) var(--gutter) var(--space-8);
    background: rgba(6, 6, 7, 0.94);
    backdrop-filter: blur(8px);
  }

  .home-min__menu[hidden] {
    display: none !important;
  }

  .home-min__menu-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .home-min__menu-close {
    align-self: flex-start;
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: none;
    border: none;
    padding: var(--space-2);
    margin: calc(var(--space-2) * -1);
    cursor: pointer;
    min-height: var(--touch-target-min);
    transition: color var(--transition-fast);
  }

  .home-min__menu-close:hover,
  .home-min__menu-close:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .home-min__menu-close:focus-visible {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .home-min__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .home-min__menu-link {
    font-size: var(--text-xl);
    letter-spacing: 0.06em;
    padding-block: var(--space-4);
    width: 100%;
    justify-content: flex-start;
  }

  .home-min__nav-link,
  .home-min__footer-link {
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    padding: var(--space-2) var(--space-2);
    margin-inline: calc(var(--space-2) * -1);
    transition: color var(--transition-fast);
  }

  .home-min__nav-link:hover,
  .home-min__nav-link:focus-visible,
  .home-min__footer-link:hover,
  .home-min__footer-link:focus-visible {
    color: var(--color-text);
  }

  .home-min__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: var(--space-12) var(--gutter) var(--space-16);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .home-min__hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(20rem, 56vh, 40rem);
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .home-min__hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .home-min__hero-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    pointer-events: none;
  }

  .home-min__hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  .home-min__hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      rgba(6, 6, 7, 0.25) 0%,
      rgba(6, 6, 7, 0.55) 42%,
      rgba(6, 6, 7, 0.88) 100%
    );
  }

  .home-min__hero-inner {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-12) var(--gutter);
  }

  .home-min__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: min(100%, var(--prose-max-ch));
    margin: 0;
    text-shadow: 0 0.06em 0.35em rgba(6, 6, 7, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-min__hero-video {
      display: none;
    }

    .home-min__hero {
      background-color: var(--color-bg);
    }

    .home-min__hero-scrim {
      background: rgba(6, 6, 7, 0.72);
    }
  }

  .home-min__event {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .home-min__event-label {
    font-family: var(--font-semi);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin: 0;
  }

  .home-min__event-link {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent-purple);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    max-width: min(100%, var(--prose-max-ch));
    transition: color var(--transition-fast);
  }

  .home-min__event-link:hover,
  .home-min__event-link:focus-visible {
    color: var(--accent-coral);
  }

  .home-min__footer {
    padding: var(--space-6) var(--gutter);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .home-min__footer-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: 0;
  }

</style>
