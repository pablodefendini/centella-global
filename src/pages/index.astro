---
import Base from '../layouts/Base.astro';
import { getFeaturedEvents } from '../lib/notion';

const events = await getFeaturedEvents();

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<Base title="Home" hideChrome={true}>
  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin slot="head" />
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow:wght@100;200;300;400;500;600;700;800;900&family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Barlow+Semi+Condensed:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <div class="home">
    <!-- ═══ NAVIGATION ═══ -->
    <nav class="nav">
      <a href="/" class="nav-logo">
        <img src="/logo.svg" alt="Centella" style="filter: brightness(0) invert(1);" />
      </a>
      <ul class="nav-links">
        <li><a href="/initiatives/advisory">Advisory</a></li>
        <li><a href="/initiatives/institute">Institute</a></li>
        <li><a href="/initiatives/impact">Impact</a></li>
        <li><a href="/about-centella">Our Story</a></li>
        <li><a href="/global-forum" class="nav-cta">Bangkok 2026</a></li>
      </ul>
    </nav>

    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div class="hero-atmosphere"></div>
      <div class="hero-ring"></div>
      <div class="hero-orb hero-orb--purple"></div>
      <div class="hero-orb hero-orb--teal"></div>
      <div class="hero-ghost">CENTELLA</div>

      <div class="hero-content">
        <div class="hero-label">Democratic Renewal</div>
        <h1 class="hero-heading">
          We <strong>re-energize</strong> movements,<br />
          restore <em>citizen power</em><br />
          Building the next generation<br />
          of <mark>democratic leaders</mark>
        </h1>
        <div class="hero-actions">
          <a href="/global-forum" class="btn-primary">
            Global Forum — Bangkok
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
          <a href="/about-centella" class="btn-ghost">
            Discover our story
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>

      <div class="hero-scroll">
        <div class="hero-scroll-line"></div>
        <span class="hero-scroll-text">Scroll</span>
      </div>
    </section>

    <!-- ═══ EVENT TICKER ═══ -->
    <a href="/global-forum" class="ticker">
      <div class="ticker-track">
        {[0, 1, 2, 3].map(() => (
          <span class="ticker-item">
            Get your ticket for the Centella Global Forum
            <span class="ticker-dot"></span>
            May 11–15, 2026
            <span class="ticker-dot"></span>
            Bangkok, Thailand
          </span>
        ))}
      </div>
    </a>

    <!-- ═══ PILLARS ═══ -->
    <section class="pillars">
      <div class="pillars-header">
        <div class="pillars-label">What we do</div>
        <h2 class="pillars-title">We focus on three <strong>foundational pillars</strong> of work</h2>
      </div>

      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-number">01</div>
          <svg class="pillar-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="24" cy="16" r="8"></circle>
            <path d="M8 42c0-8.837 7.163-16 16-16s16 7.163 16 16"></path>
            <path d="M32 8l4 4-4 4"></path>
          </svg>
          <h3 class="pillar-name">Advising Leaders</h3>
          <p class="pillar-desc">We support leaders with hands-on coaching and strategy development to help them win campaigns and defend democratic institutions.</p>
          <a href="/initiatives/advisory" class="pillar-link">
            Learn more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>

        <div class="pillar-card">
          <div class="pillar-number">02</div>
          <svg class="pillar-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="24" cy="24" r="4"></circle>
            <circle cx="10" cy="12" r="3"></circle>
            <circle cx="38" cy="12" r="3"></circle>
            <circle cx="10" cy="36" r="3"></circle>
            <circle cx="38" cy="36" r="3"></circle>
            <line x1="21" y1="21" x2="12.5" y2="14"></line>
            <line x1="27" y1="21" x2="35.5" y2="14"></line>
            <line x1="21" y1="27" x2="12.5" y2="34"></line>
            <line x1="27" y1="27" x2="35.5" y2="34"></line>
          </svg>
          <h3 class="pillar-name">Building Networks</h3>
          <p class="pillar-desc">We create and facilitate spaces that connect movement leaders across borders, accelerating ideas into action through shared wisdom.</p>
          <a href="/initiatives/institute" class="pillar-link">
            Learn more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>

        <div class="pillar-card">
          <div class="pillar-number">03</div>
          <svg class="pillar-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="8" width="36" height="28" rx="3"></rect>
            <line x1="6" y1="28" x2="42" y2="28"></line>
            <polyline points="18 40 24 44 30 40"></polyline>
            <path d="M20 18l-4 4 4 4"></path>
            <path d="M28 18l4 4-4 4"></path>
          </svg>
          <h3 class="pillar-name">Investing in Tech</h3>
          <p class="pillar-desc">We fuel and advise next-generation civic tech created in the Global South, where scarce resources call for ingenious solutions.</p>
          <a href="/initiatives/impact" class="pillar-link">
            Learn more
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    </section>

    {events.length > 0 && (
      <section class="events">
        <div class="events-inner">
          <div class="events-header">
            <div class="events-label">Upcoming</div>
            <h2 class="events-title">Events & <strong>gatherings</strong></h2>
          </div>
          <div class="events-grid">
            {events.map((event) => (
              <a href={`/events/${event.slug}/`} class="event-card">
                {event.heroImage && (
                  <div class="event-card-media">
                    <img src={event.heroImage} alt={event.name} loading="lazy" />
                  </div>
                )}
                <div class="event-card-body">
                  <time class="event-card-date">{formatDate(event.dateStart)}</time>
                  <h3 class="event-card-title">{event.name}</h3>
                  {event.tagline && <p class="event-card-tagline">{event.tagline}</p>}
                  {event.location && <p class="event-card-location">{event.location}</p>}
                </div>
              </a>
            ))}
          </div>
          <a href="/events/" class="events-all">
            View all events
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </section>
    )}

    <!-- ═══ MANIFESTO ═══ -->
    <section class="manifesto">
      <div class="manifesto-bg"></div>
      <div class="manifesto-grid">
        <div class="manifesto-text">
          <div class="manifesto-label">Our Manifesto</div>
          <blockquote class="manifesto-quote">
            Ready to <strong>spark the revival</strong> with us?
          </blockquote>
          <p class="manifesto-body">
            Centella answers the call to re-energize movements, restore citizen power, and build the next generation of democratic leaders — drawing on decades of frontline experience in democratic movements worldwide.
          </p>
          <a href="/about-centella" class="btn-primary">
            Read our manifesto
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
        <div class="manifesto-visual">
          <div class="geo-comp">
            <div class="geo-circle geo-circle--outer"></div>
            <div class="geo-circle geo-circle--mid"></div>
            <div class="geo-circle geo-circle--inner"></div>
            <div class="geo-dot geo-dot--purple"></div>
            <div class="geo-dot geo-dot--teal"></div>
            <div class="geo-dot geo-dot--coral"></div>
            <div class="geo-center-text">✦</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ MAILING LIST ═══ -->
    <section class="signup">
      <div class="signup-inner">
        <h2 class="signup-heading">Stay close.</h2>
        <p class="signup-sub">Sign up for our mailing list to stay up to date on our progress.</p>
        <form class="signup-form" data-tag="homepage-signup">
          <input
            type="email"
            name="email"
            class="signup-input"
            placeholder="name@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="signup-btn">Sign up</button>
        </form>
        <p class="signup-status" aria-live="polite"></p>
      </div>
    </section>

    <!-- ═══ ORIGIN STORY ═══ -->
    <section class="origin">
      <div class="origin-inner">
        <div class="origin-visual">
          <div class="origin-image-placeholder"></div>
        </div>
        <div>
          <div class="origin-label">The Spark Behind the Movement</div>
          <h2 class="origin-heading">
            Born from decades of <strong>frontline experience</strong>
          </h2>
          <p class="origin-body">
            Centella was born from decades of frontline experience in democratic movements worldwide. We know what it takes to build power, sustain momentum, and win — and we're here to share that knowledge with a new generation.
          </p>
          <a href="/about-centella" class="origin-link">
            Discover our story
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="footer-logo">
              <img src="/logo.svg" alt="Centella" style="filter: brightness(0) invert(1); opacity: 0.5;" />
            </div>
            <p class="footer-tagline">
              We re-energize movements, restore citizen power, and build the next generation of democratic leaders.
            </p>
          </div>
          <div>
            <h4 class="footer-col-title">Initiatives</h4>
            <ul class="footer-links">
              <li><a href="/initiatives/advisory">Global Advisory</a></li>
              <li><a href="/initiatives/institute">Centella Institute</a></li>
              <li><a href="/initiatives/impact">Centella Impact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="footer-col-title">About</h4>
            <ul class="footer-links">
              <li><a href="/about-centella">Our Story</a></li>
              <li><a href="/global-forum">Global Forum</a></li>
              <li><a href="/events/">Events</a></li>
              <li><a href="/blog/">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4 class="footer-col-title">Connect</h4>
            <ul class="footer-links">
              <li><a href="https://www.instagram.com/centellaglobal/" target="_blank" rel="noopener">Instagram</a></li>
              <li><a href="https://www.linkedin.com/company/centella-global" target="_blank" rel="noopener">LinkedIn</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span class="footer-copy">&copy; {new Date().getFullYear()} Centella</span>
          <div class="footer-socials">
            <a href="https://www.instagram.com/centellaglobal/" target="_blank" rel="noopener" class="footer-social" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                <circle cx="12" cy="12" r="5"></circle>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"></circle>
              </svg>
            </a>
            <a href="https://www.linkedin.com/company/centella-global" target="_blank" rel="noopener" class="footer-social" aria-label="LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Base>

<script>
  const form = document.querySelector<HTMLFormElement>('.home .signup-form');
  if (form) {
    const status = document.querySelector<HTMLElement>('.home .signup-status')!;
    const btn = form.querySelector<HTMLButtonElement>('.signup-btn')!;
    const email = form.querySelector<HTMLInputElement>('input[type=email]')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Subscribing…';
      status.textContent = '';
      status.className = 'signup-status';
      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email.value, tag: form.dataset.tag }),
        });
        if (res.ok) {
          status.textContent = 'Thanks for subscribing!';
          status.classList.add('signup-status--success');
          email.value = '';
        } else {
          const data = await res.json().catch(() => ({}));
          status.textContent = data.error ?? 'Something went wrong. Please try again.';
          status.classList.add('signup-status--error');
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.classList.add('signup-status--error');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  }
</script>

<style is:global>
  /* ═══════════════════════════════════════════
     DESIGN SYSTEM — Centella Global Redesign
     Scoped under .home so tokens don't leak.
     ═══════════════════════════════════════════ */

  .home {
    /* Brand Colors */
    --bg-deep: #060607;
    --bg-primary: #080809;
    --bg-surface: #0D0D0F;
    --bg-elevated: #151517;
    --bg-lavender: #F7EDFF;

    --accent-teal: #00A3B6;
    --accent-cyan: #00E5FF;
    --accent-coral: #FF6B6B;
    --accent-green: #6EA92B;
    --accent-lime: #CCFF00;
    --accent-purple: #C77DFF;
    --accent-orange: #FF9500;
    --accent-pink: #FF66C4;

    --grad-violet-coral: linear-gradient(135deg, var(--accent-purple), var(--accent-coral));
    --grad-teal-lime: linear-gradient(135deg, var(--accent-cyan), var(--accent-lime));
    --grad-coral-orange: linear-gradient(135deg, var(--accent-coral), var(--accent-orange));
    --grad-pink-violet: linear-gradient(135deg, var(--accent-pink), var(--accent-purple));
    --grad-teal-violet: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
    --grad-lime-teal: linear-gradient(135deg, var(--accent-lime), var(--accent-teal));
    --grad-orange-pink: linear-gradient(135deg, var(--accent-orange), var(--accent-pink));

    --text-primary: #F7EDFF;
    --text-secondary: rgba(247, 237, 255, 0.6);
    --text-muted: rgba(247, 237, 255, 0.35);
    --text-dark: #1E1A28;

    --font-display: 'Barlow Condensed', sans-serif;
    --font-heading: 'Barlow', sans-serif;
    --font-body: 'Barlow', sans-serif;
    --font-semi: 'Barlow Semi Condensed', sans-serif;

    --text-xs: 0.6875rem;
    --text-sm: 0.8125rem;
    --text-base: 1rem;
    --text-lg: 1.25rem;
    --text-xl: 1.5rem;
    --text-2xl: 2rem;
    --text-3xl: 2.75rem;
    --text-4xl: 3.75rem;
    --text-hero: clamp(5rem, 12vw, 9rem);

    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-24: 6rem;
    --space-32: 8rem;

    --radius: 6px;
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-dramatic: cubic-bezier(0.77, 0, 0.175, 1);
    --duration: 200ms;

    background: var(--bg-deep);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  .home * { box-sizing: border-box; }
  .home a { color: inherit; text-decoration: none; }
  .home img { max-width: 100%; display: block; }
  .home ul { list-style: none; margin: 0; padding: 0; }
  .home h1, .home h2, .home h3, .home h4, .home h5 { margin: 0; font-weight: inherit; }
  .home p { margin: 0; }
  .home ::selection { background: rgba(199, 125, 255, 0.2); color: var(--text-primary); }

  /* ─── Animations ─── */
  @keyframes homeFadeUp { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes homeFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes homeSlideFromLeft { from { opacity: 0; transform: translateX(-60px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes homeSlideFromRight { from { opacity: 0; transform: translateX(60px); } to { opacity: 1; transform: translateX(0); } }
  @keyframes homeGradientDrift { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
  @keyframes homeFloat { 0%,100% { transform: translateY(0) rotate(0deg); } 33% { transform: translateY(-14px) rotate(1.5deg); } 66% { transform: translateY(8px) rotate(-1deg); } }
  @keyframes homePulseGlow { 0%,100% { opacity: 0.4; } 50% { opacity: 0.8; } }
  @keyframes homeSlowSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes homeOrbit { from { transform: rotate(0deg) translateX(120px) rotate(0deg); } to { transform: rotate(360deg) translateX(120px) rotate(-360deg); } }
  @keyframes homeTickerScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  @media (prefers-reduced-motion: reduce) {
    .home *, .home *::before, .home *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ═══ NAVIGATION ═══ */
  .home .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: var(--space-4) var(--space-8);
    display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-3);
    background: linear-gradient(to bottom, rgba(6,6,7,0.95), rgba(6,6,7,0));
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    animation: homeFadeIn 0.8s var(--ease) forwards;
  }
  .home .nav-logo { height: 28px; width: auto; opacity: 0; animation: homeSlideFromLeft 0.7s var(--ease) 0.2s forwards; }
  .home .nav-logo img { height: 100%; width: auto; }
  .home .nav-links { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-3) var(--space-6); width: 100%; opacity: 0; animation: homeSlideFromRight 0.7s var(--ease) 0.3s forwards; }
  @media (min-width: 640px) { .home .nav-links { gap: var(--space-4) var(--space-8); } }
  .home .nav-links a {
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color var(--duration) var(--ease);
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    padding: var(--space-2) var(--space-3);
    margin-inline: calc(var(--space-3) * -0.5);
  }
  .home .nav-links a::after { content: ''; position: absolute; bottom: var(--space-2); left: var(--space-3); width: 0; height: 1.5px; background: var(--accent-purple); transition: width 0.3s var(--ease); }
  .home .nav-links a:hover { color: var(--text-primary); }
  .home .nav-links a:hover::after { width: calc(100% - 2 * var(--space-3)); }
  .home .nav-cta {
    font-family: var(--font-semi) !important;
    font-size: var(--text-xs) !important;
    font-weight: 600 !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: var(--touch-target-min) !important;
    padding: var(--space-2) var(--space-6) !important;
    background: var(--accent-coral);
    color: var(--bg-deep) !important;
    border-radius: 8px;
    letter-spacing: 0.1em !important;
    transition: all 0.25s var(--ease);
  }
