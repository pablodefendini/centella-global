---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { getHomepageLatestEvent } from '../lib/notion';

const latestEvent = await getHomepageLatestEvent();

const heroPoster = '/media/hero/centella-hero-bg-poster.webp';
const heroVideo720 = '/media/hero/centella-hero-bg-720.mp4';
const heroVideo540 = '/media/hero/centella-hero-bg-540.mp4';
const foundationalPillars = [
  {
    icon: 'hands-clasping',
    title: 'Advising leaders',
    body: 'We support leaders with hands-on coaching and strategy development to help them win campaigns and deliver lasting change.',
    cta: 'Learn more about Centella Advisory',
    href: '/centella-advisory/',
    tone: 'advisory',
  },
  {
    icon: 'globe-grid',
    title: 'Building networks',
    body: 'We create and facilitate spaces that connect movement leaders across borders, accelerating ideas into collective action.',
    cta: 'Learn more about the Centella Institute',
    href: '/centella-institute/',
    tone: 'networking',
  },
  {
    icon: 'money-bag',
    title: 'Investing in tech',
    body: 'We fuel and advise next-generation civic tech created in the Global South, where scarce resources can go further.',
    cta: 'Learn more about Centella Impact',
    href: '/centella-impact/',
    tone: 'investment',
  },
] as const;
---

<Base title="Home">
  <div class="home-min">
    <section class="home-min__hero" aria-labelledby="home-hero-heading">
      <div class="home-min__hero-media" aria-hidden="true">
        <img
          class="home-min__hero-poster"
          src={heroPoster}
          alt=""
          width="1600"
          height="800"
          fetchpriority="high"
          decoding="async"
        />
        <video
          id="home-hero-video"
          class="home-min__hero-video"
          muted
          loop
          playsinline
          preload="none"
          poster={heroPoster}
        />
        <div class="home-min__hero-scrim"></div>
      </div>
      <div class="home-min__hero-inner">
        <h1 id="home-hero-heading" class="home-min__headline">
          We re-energize movements,<br />
          restore citizen power, and build the next generation of democratic leaders
        </h1>
      </div>
    </section>

    <script is:inline define:vars={{ heroVideo720, heroVideo540 }}>
      (function () {
        var video = document.getElementById('home-hero-video');
        if (!video) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
        if (conn) {
          if (conn.saveData) return;
          var t = conn.effectiveType;
          if (t === 'slow-2g' || t === '2g' || t === '3g') return;
        }

        var narrow = window.matchMedia('(max-width: 639px)').matches;
        video.src = narrow ? heroVideo540 : heroVideo720;
        video.load();
        var p = video.play();
        if (p && typeof p.catch === 'function') p.catch(function () {});
      })();
    </script>

    <div class="home-min__main">
      {latestEvent && (
        <section class="home-min__event" aria-labelledby="home-event-heading">
          <h2 id="home-event-heading" class="home-min__event-label">Latest event</h2>
          <a href={`/events/${latestEvent.slug}/`} class="home-min__event-link">
            {latestEvent.name}
          </a>
        </section>
      )}

      <section class="home-min__pillars" aria-labelledby="home-pillars-heading">
        <h2 id="home-pillars-heading" class="home-min__pillars-title">
          Centella focuses on three foundational pillars of work:
        </h2>
        <div class="home-min__pillars-list" role="list">
          {foundationalPillars.map((pillar) => (
            <article class:list={['home-min__pillar', `home-min__pillar--${pillar.tone}`]} role="listitem">
              <div class="home-min__pillar-frame">
                <div class="home-min__pillar-icon-wrap">
                  <Icon name={pillar.icon} size={32} class="home-min__pillar-icon" label={`${pillar.title} icon`} />
                </div>
                <h3 class="home-min__pillar-title">{pillar.title}</h3>
                <p class="home-min__pillar-body">{pillar.body}</p>
                <a href={pillar.href} class="home-min__pillar-cta">{pillar.cta}</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>

  </div>
</Base>

<style>
  .home-min {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    isolation: isolate;
    background: var(--color-bg);
    color: var(--color-text);
    overflow-x: clip;
  }


  .home-min__main {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    padding: var(--space-12) var(--gutter) var(--space-16);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .home-min__hero-media {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: clamp(20rem, 56vh, 40rem);
    z-index: 0;
  }

  .home-min__hero {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    min-height: clamp(20rem, 56vh, 40rem);
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .home-min__hero-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    pointer-events: none;
  }

  .home-min__hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  .home-min__hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      rgba(6, 6, 7, 0.25) 0%,
      rgba(6, 6, 7, 0.55) 42%,
      rgba(6, 6, 7, 0.88) 100%
    );
  }

  .home-min__hero-inner {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-12) var(--gutter);
  }

  .home-min__headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
    max-width: min(100%, var(--prose-max-ch));
    margin: 0;
    text-shadow: 0 0.06em 0.35em rgba(6, 6, 7, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-min__hero-video {
      display: none;
    }

    .home-min__hero {
      background-color: var(--color-bg);
    }

    .home-min__hero-scrim {
      background: rgba(6, 6, 7, 0.72);
    }
  }

  .home-min__event {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .home-min__event-label {
    font-family: var(--font-semi);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin: 0;
  }

  .home-min__event-link {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent-purple);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: var(--touch-target-min);
    max-width: min(100%, var(--prose-max-ch));
    transition: color var(--transition-fast);
  }

  .home-min__event-link:hover,
  .home-min__event-link:focus-visible {
    color: var(--accent-coral);
  }

  .home-min__pillars {
    margin-top: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .home-min__pillars-title {
    margin: 0;
    max-width: min(100%, 32ch);
    font-family: var(--font-display);
    font-size: clamp(1.875rem, 4.5vw, var(--text-3xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .home-min__pillars-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .home-min__pillar {
    border-radius: 8px;
    padding: var(--space-2);
    color: var(--color-text);
  }

  .home-min__pillar-frame {
    border-radius: inherit;
    border: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    padding: var(--space-8) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .home-min__pillar--advisory {
    background: var(--advisory-dark);
    color: var(--advisory);
  }

  .home-min__pillar--networking {
    background: var(--networking-dark);
    color: var(--networking);
  }

  .home-min__pillar--investment {
    background: var(--investment-dark);
    color: var(--investment);
  }

  .home-min__pillar-icon-wrap {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: color-mix(in srgb, currentColor 16%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
    padding: var(--space-2);
  }

  .home-min__pillar-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .home-min__pillar-body {
    margin: 0;
    max-width: 62ch;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  .home-min__pillar-cta {
    width: fit-content;
    text-decoration: none;
    min-height: var(--touch-target-min);
    display: inline-flex;
    align-items: center;
    font-family: var(--font-semi);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    border-bottom: 1px solid color-mix(in srgb, currentColor 55%, transparent);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .home-min__pillar-cta:hover,
  .home-min__pillar-cta:focus-visible {
    color: color-mix(in srgb, currentColor 72%, var(--color-text));
    border-color: currentColor;
  }

</style>
