---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import MailchimpForm from '../components/MailchimpForm.astro';
import { getTeamProfiles } from '../lib/notion';

/**
 * About Centella — umbrella page introducing the organization, the moment,
 * the team, and the three pillars of work. Keyed to the neutral default
 * --page-accent (--violet-light) so the chrome stays principal-brand-neutral.
 *
 * Team grid is driven by getTeamProfiles() from Notion. Photos come from
 * public/team/<slug>.webp, written at build time by scripts/build-team-photos.mjs
 * (Notion's signed file URLs expire, so we can't hotlink). When a profile
 * has no photo or no slug, the panel falls back to initials.
 */

const teamProfiles = await getTeamProfiles();

/** Initials helper for the photo-fallback chip — first letter of each word, max 2. */
function initialsFor(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .map((w) => w[0]?.toUpperCase() ?? '')
    .slice(0, 2)
    .join('');
}

/**
 * Color cycle for team panels. Order matches the styleguide colorFamilies
 * array (principal brand first, then work colors). Each panel keys to one
 * family — bg + foreground + duotone filter. With 7 active profiles, the
 * 7th wraps back to violet. The "max two color families per composition"
 * rule still holds because each panel is its own composition.
 */
const teamFamilies = ['violet', 'advisory', 'networking', 'investment', 'global', 'tech'] as const;

const moments = [
  {
    icon: 'action',
    title: 'Act fast',
    body: 'Rapidly monitor changing political, technological and social contexts and swiftly deploy creative, pragmatic strategies and with precision.',
  },
  {
    icon: 'trust',
    title: 'Lead boldly',
    body: 'Leaders must be effective, ethical, and values-based — principled decision makers that inspire collective action while remaining accountable to the communities they serve.',
  },
  {
    icon: 'power-fist',
    title: 'Mobilize deep',
    body: 'Movements need concrete alternatives rooted in material realities and a vision for long-term systemic change.',
  },
  {
    icon: 'globe-grid',
    title: 'Work from local to global',
    body: "Solidarity across borders and a connected, multi-scale approach aren't optional — collaboration is the path toward prosperity.",
  },
  {
    icon: 'tools',
    title: 'Democratize digital power',
    body: 'Technology must be affordable, accessible, and effective to organizers worldwide, not always confined to elites.',
  },
] as const;

const regionalStats = [
  {
    region: 'Latin America',
    figure: '18.9 million',
    body: 'Instagram users in Latin America. Same density as in the U.S.',
  },
  {
    region: 'Africa',
    figure: '$3.2 billion',
    body: "Value of the creator economy in Africa, projected to grow 5× by 2030.",
  },
  {
    region: 'Asia',
    figure: '$135 billion',
    body: "Value of the creator economy in Asia, projected to grow 6× by 2030.",
  },
] as const;

const formula = [
  {
    title: 'Sharper strategies',
    body: 'Ignite winning campaigns with data-driven insight and bold creative vision that cuts through the noise.',
  },
  {
    title: 'Shared learning',
    body: 'Build unstoppable networks through solidarity, knowledge exchange, and the power of collective momentum.',
  },
  {
    title: 'Accessible technology',
    body: 'Empower voices everywhere with affordable, effective digital tools.',
  },
] as const;

const pillars = [
  {
    icon: 'hands-clasping',
    tone: 'advisory',
    title: 'Advising leaders',
    body: 'We support leaders with hands-on coaching and strategy development to help them win campaigns and deliver lasting change.',
    cta: 'Learn more',
    href: '/centella-advisory/',
  },
  {
    icon: 'globe-grid',
    tone: 'networking',
    title: 'Building networks',
    body: 'We create and facilitate spaces that connect movement leaders across borders, accelerating ideas into collective action.',
    cta: 'Learn more',
    href: '/centella-institute/',
  },
  {
    icon: 'money-bag',
    tone: 'investment',
    title: 'Investing in tech',
    body: 'We fund and advise next-generation civic-tech created in the Global South, where scarce resources can go further.',
    cta: 'Learn more',
    href: '/centella-impact/',
  },
] as const;
---

<Base
  title="About Centella"
  description="Movement builders from the Global South. We partner with leaders, networks, and civic-tech founders refusing to accept the status quo."
>
  <!-- ── Hero ───────────────────────────────────────── -->
  <section class="section about-hero" aria-labelledby="about-hero-heading">
    <div class="container">
      <h1 id="about-hero-heading" class="display about-hero__title">
        We believe in the power of{' '}
        <span class="display__accent" data-random-accent-gradient>sustained growth</span>.
      </h1>
    </div>
  </section>

  <!-- ── Section 1 — Meet the moment ────────────────── -->
  <section class="section about-moments" aria-labelledby="about-moments-heading">
    <div class="container about-section-intro">
      <h2 id="about-moments-heading" class="about-section-title">
        It's time to meet the moment.
      </h2>
      <p class="lede about-section-lede">To start winning again, we need to:</p>
    </div>

    <div class="container">
      <ul class="about-moments-grid" role="list">
        {moments.map((m) => (
          <li class="about-moment">
            <span class="about-moment__icon-wrap" aria-hidden="true">
              <Icon name={m.icon} size={32} class="about-moment__icon" />
            </span>
            <h3 class="about-moment__title">{m.title}</h3>
            <p class="about-moment__body">{m.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Section 2 — Flip the script ────────────────── -->
  <section class="section about-flip" aria-labelledby="about-flip-heading">
    <div class="container about-section-intro">
      <h2 id="about-flip-heading" class="about-section-title">…and flip the script.</h2>
    </div>

    <div class="container about-flip__featured">
      <span class="about-flip__featured-icon" aria-hidden="true">
        <Icon name="globe" size={56} />
      </span>
      <p class="about-flip__featured-stat">80%</p>
      <p class="lede about-flip__featured-body">
        of the world's population is in the Global South, most of them under 30.
      </p>
    </div>

    <div class="container">
      <ul class="about-flip-grid" role="list">
        {regionalStats.map((s) => (
          <li class="about-flip-card">
            <p class="about-flip-card__region">{s.region}</p>
            <p class="about-flip-card__figure">{s.figure}</p>
            <p class="about-flip-card__body">{s.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Section 3 — The team ───────────────────────── -->
  <!--
    Duotone filters for team-panel photos. One per family. Each maps the
    photo's grayscale luminance to that family's dark→bright color range.
    The grayscale step (feColorMatrix) is shared shape; only the
    feFunc* tableValues change per family.
    Critical: <feFunc*> must carry type="table" — without it the function
    defaults to "identity" and tableValues are silently ignored.
    Per-family tableValues are computed by normalizing each family's
    --<family>-dark / --<family> hex values to 0..1 (R/G/B). If the
    family tokens ever change, update the corresponding values here.
    See design.md → Photography → Duotone filter for the full table.
  -->
  <svg aria-hidden="true" focusable="false" class="about-team-duotone-defs">
    <defs>
      <filter id="duotone-violet" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.118 0.78"/>
          <feFuncG type="table" tableValues="0.102 0.49"/>
          <feFuncB type="table" tableValues="0.157 1"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-advisory" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.055 0"/>
          <feFuncG type="table" tableValues="0.133 0.898"/>
          <feFuncB type="table" tableValues="0.157 1"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-networking" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.133 1"/>
          <feFuncG type="table" tableValues="0.094 0.42"/>
          <feFuncB type="table" tableValues="0.110 0.42"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-investment" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.118 0.8"/>
          <feFuncG type="table" tableValues="0.141 1"/>
          <feFuncB type="table" tableValues="0.075 0"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-global" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.188 1"/>
          <feFuncG type="table" tableValues="0.110 0.584"/>
          <feFuncB type="table" tableValues="0 0"/>
        </feComponentTransfer>
      </filter>
      <filter id="duotone-tech" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0.299 0.587 0.114 0 0 0 0 0 1 0"/>
        <feComponentTransfer>
          <feFuncR type="table" tableValues="0.165 1"/>
          <feFuncG type="table" tableValues="0.082 0.4"/>
          <feFuncB type="table" tableValues="0.133 0.769"/>
        </feComponentTransfer>
      </filter>
    </defs>
  </svg>

  <section class="section about-team" aria-labelledby="about-team-heading">
    <div class="container about-section-intro">
      <h2 id="about-team-heading" class="about-section-title">
        We are movement builders from the Global South.
      </h2>
      <p class="lede about-section-lede">
        With practical experience, strong convictions, decades of experience turning scarce
        resources into historic victories, and a focus on sustainability.
      </p>
    </div>

    <div class="container">
      {teamProfiles.length === 0 ? (
        <p class="about-team__empty">Team profiles publishing soon.</p>
      ) : (
        <div class="about-team-grid" role="list" aria-label="Centella team">
          {teamProfiles.map((person, i) => {
            const family = teamFamilies[i % teamFamilies.length];
            return (
            <details name="centella-team" class:list={['expanding-panel', 'expanding-panel--toned', 'expanding-panel--floating', 'about-team-card', `about-team-card--${family}`]} role="listitem">
              <summary class="expanding-panel__head about-team-card__head">
                <span class="about-team-card__photo" aria-hidden="true">
                  <span class="about-team-card__initials">{initialsFor(person.name)}</span>
                  {person.slug && (
                    <img
                      class="about-team-card__photo-img"
                      src={`/team/${person.slug}.webp`}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none'"
                    />
                  )}
                </span>
                <span class="about-team-card__stack">
                  <span class="about-team-card__name">{person.name}</span>
                  {person.title && (
                    <span class="about-team-card__title">{person.title}</span>
                  )}
                </span>
                <span class="expanding-panel__chevron" aria-hidden="true"></span>
              </summary>
              <div class="expanding-panel__body about-team-card__body">
                {person.bio || person.biography || (
                  <span class="about-team-card__no-bio">Bio coming soon.</span>
                )}
              </div>
            </details>
            );
          })}
        </div>
      )}

      <p class="lede about-team__closing">
        Centered in the Global South, connected worldwide — we partner with those who refuse
        to accept the status quo.
      </p>
    </div>
  </section>

  <!-- ── Section 4 — The approach ───────────────────── -->
  <section class="section about-formula" aria-labelledby="about-formula-heading">
    <div class="container about-section-intro">
      <h2 id="about-formula-heading" class="about-section-title">Our winning formula.</h2>
    </div>

    <div class="container">
      <ul class="about-formula-grid" role="list">
        {formula.map((f) => (
          <li class="about-formula-card">
            <h3 class="about-formula-card__title">{f.title}</h3>
            <p class="about-formula-card__body">{f.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── Section 5 — The work (three pillars) ──────── -->
  <section class="section about-pillars" aria-labelledby="about-pillars-heading">
    <div class="container about-section-intro">
      <h2 id="about-pillars-heading" class="about-section-title">
        Grounded in three pillars of work.
      </h2>
    </div>

    <div class="container">
      <div class="about-pillars-grid" role="list">
        {pillars.map((p) => (
          <article class:list={['about-pillar', 'tone-surface', `about-pillar--${p.tone}`]} role="listitem">
            <div class="about-pillar__frame">
              <span class="about-pillar__icon-wrap" aria-hidden="true">
                <Icon name={p.icon} size={32} class="about-pillar__icon" />
              </span>
              <h3 class="about-pillar__title">{p.title}</h3>
              <p class="about-pillar__body">{p.body}</p>
              <a href={p.href} class="about-pillar__cta">
                {p.cta}
                <span aria-hidden="true"> →</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Section 6 — Email signup ───────────────────── -->
  <section class="section about-signup" aria-labelledby="about-signup-heading">
    <div class="container about-signup__inner">
      <h2 id="about-signup-heading" class="about-section-title about-signup__title">
        Stay close to the work.
      </h2>
      <p class="lede about-signup__lede">
        Occasional dispatches from Centella — campaigns we're shaping, leaders we're backing,
        and the civic-tech we're building for the Global South.
      </p>
      <MailchimpForm tag="centella-newsletter" />
    </div>
  </section>
</Base>

<style>
  /* ─────────────────────────────────────────────────────
     Page-local styles for /about-centella.
     Tokens only — no new color, spacing, or radius values.
     Page is principal-brand-neutral (default --page-accent =
     --violet-light); each section sets its own local accent
     where needed (Section 2 keys to --global; Section 5
     pillars to advisory / networking / investment).
     ───────────────────────────────────────────────────── */

  /* Hero */
  .about-hero { padding-top: var(--space-16); }

  .about-hero__title {
    color: var(--color-text);
    max-width: min(100%, 22ch);
    margin: 0;
  }

  /* Shared section intro */
  .about-section-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: min(100%, var(--prose-max-ch));
    margin-bottom: var(--space-12);
  }

  .about-section-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .about-section-lede { margin: 0; color: var(--color-text-muted); }

  /* ── Section 1 — Meet the moment (icon cards, 2-col) ── */
  .about-moments-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .about-moments-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .about-moment {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-moment__icon-wrap {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    color: var(--violet);
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--violet) 30%, transparent);
    padding: var(--space-2);
  }

  .about-moment__title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
    letter-spacing: -0.01em;
    color: var(--color-text);
  }

  .about-moment__body {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  /* ── Section 2 — Flip the script (stats, --global key) ── */
  .about-flip__featured {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-16);
    color: var(--global);
  }

  .about-flip__featured-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--global);
  }

  .about-flip__featured-stat {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(4rem, 14vw, 8rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--global);
  }

  .about-flip__featured-body {
    margin: 0;
    color: var(--color-text);
    max-width: 48ch;
  }

  .about-flip-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  @media (min-width: 640px) {
    .about-flip-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .about-flip-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-2);
    border-top: 3px solid var(--global);
  }

  .about-flip-card__region {
    margin: 0;
    font-family: var(--font-semi);
    font-weight: 600;
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--global);
  }

  .about-flip-card__figure {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(var(--text-4xl), 5vw, var(--text-5xl));
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .about-flip-card__body {
    margin: 0;
    color: var(--color-text-muted);
  }

  /* ── Section 3 — The team (expanding panels) ── */
  .about-team-grid {
    margin: 0 0 var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .about-team-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .about-team-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Team panels cycle through the six families in display order. Each
     panel is its own composition — the "max two color families per
     composition" rule applies per panel, not to the aggregate, so a
     grid of differently-toned cards is brand-legal. The duotone filter
     for each panel keys to the same family via the .about-team-card--<family>
     class below.
     --tone-dark / --tone are exposed as custom properties so children
     (the floating body in particular) can pick them up via inheritance. */
  .about-team-card--violet     { --tone-dark: var(--violet-dark);     --tone: var(--violet);     background: var(--tone-dark); color: var(--tone); }
  .about-team-card--advisory   { --tone-dark: var(--advisory-dark);   --tone: var(--advisory);   background: var(--tone-dark); color: var(--tone); }
  .about-team-card--networking { --tone-dark: var(--networking-dark); --tone: var(--networking); background: var(--tone-dark); color: var(--tone); }
  .about-team-card--investment { --tone-dark: var(--investment-dark); --tone: var(--investment); background: var(--tone-dark); color: var(--tone); }
  .about-team-card--global     { --tone-dark: var(--global-dark);     --tone: var(--global);     background: var(--tone-dark); color: var(--tone); }
  .about-team-card--tech       { --tone-dark: var(--tech-dark);       --tone: var(--tech);       background: var(--tone-dark); color: var(--tone); }

  .about-team-card--violet     .about-team-card__photo-img { filter: url(#duotone-violet); }
  .about-team-card--advisory   .about-team-card__photo-img { filter: url(#duotone-advisory); }
  .about-team-card--networking .about-team-card__photo-img { filter: url(#duotone-networking); }
  .about-team-card--investment .about-team-card__photo-img { filter: url(#duotone-investment); }
  .about-team-card--global     .about-team-card__photo-img { filter: url(#duotone-global); }
  .about-team-card--tech       .about-team-card__photo-img { filter: url(#duotone-tech); }

  .about-team-card__head { gap: var(--space-4); }

  /* Photo wrapper: icon-chip base layer, initials inside, optional img overlay.
     If the img fails to load (or no slug), initials show through; if it loads,
     it covers the initials. Single visual element, graceful fallback. */
  .about-team-card__photo {
    position: relative;
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    overflow: hidden;
    /* Echoes the icon-chip recipe from tone-panels: family-tinted bg + family-keyed border */
    background: color-mix(in srgb, currentColor 16%, transparent);
    border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .about-team-card__initials {
    color: currentColor;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-base);
    letter-spacing: 0.02em;
  }

  .about-team-card__photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Duotone filter is set per-family by .about-team-card--<family>
       above. Defs live in the SVG block at the top of this section. */
  }

  /* Visually hidden SVG defs container — defines the filter referenced above. */
  .about-team-duotone-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .about-team-card__stack {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .about-team-card__name {
    /* Per tone-panel rule: title in --color-text on family-dark grounds */
    color: var(--color-text);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-base);
    line-height: var(--leading-tight);
  }

  .about-team-card__title {
    /* Family-keyed muted: currentColor at reduced opacity reads as "advisory but quieter" */
    color: color-mix(in srgb, currentColor 80%, transparent);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .about-team-card__no-bio {
    color: color-mix(in srgb, currentColor 60%, transparent);
    font-style: italic;
  }

