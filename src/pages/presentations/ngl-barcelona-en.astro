    width: 100%;
    accent-color: #c77dff;
  }
</style>
<script is:inline>
(function() {
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "logoCoverH": 160,
    "logoChromeH": 72
  }/*EDITMODE-END*/;

  const state = { ...TWEAK_DEFAULTS };

  function apply() {
    document.documentElement.style.setProperty('--logo-cover-h', state.logoCoverH + 'px');
    document.documentElement.style.setProperty('--logo-chrome-h', state.logoChromeH + 'px');
  }
  apply();

  function persist(patch) {
    try {
      window.parent.postMessage({ type: '__edit_mode_set_keys', edits: patch }, '*');
    } catch (e) {}
  }

  let panel;
  function buildPanel() {
    if (panel) return panel;
    panel = document.createElement('div');
    panel.id = 'tweaks-panel';
    panel.innerHTML = `
      <h3>Tweaks</h3>
      <div class="tk-row">
        <label>Cover logo <span class="val" id="tk-cover-val">${state.logoCoverH}px</span></label>
        <input type="range" id="tk-cover" min="24" max="160" step="1" value="${state.logoCoverH}">
      </div>
      <div class="tk-row">
        <label>Chrome logo <span class="val" id="tk-chrome-val">${state.logoChromeH}px</span></label>
        <input type="range" id="tk-chrome" min="16" max="72" step="1" value="${state.logoChromeH}">
      </div>
    `;
    document.body.appendChild(panel);
    const cover = panel.querySelector('#tk-cover');
    const coverVal = panel.querySelector('#tk-cover-val');
    cover.addEventListener('input', () => {
      state.logoCoverH = +cover.value;
      coverVal.textContent = state.logoCoverH + 'px';
      apply();
      persist({ logoCoverH: state.logoCoverH });
    });
    const chrome = panel.querySelector('#tk-chrome');
    const chromeVal = panel.querySelector('#tk-chrome-val');
    chrome.addEventListener('input', () => {
      state.logoChromeH = +chrome.value;
      chromeVal.textContent = state.logoChromeH + 'px';
      apply();
      persist({ logoChromeH: state.logoChromeH });
    });
    return panel;
  }

  window.addEventListener('message', (e) => {
    const d = e.data;
    if (!d || !d.type) return;
    if (d.type === '__activate_edit_mode') {
      buildPanel().setAttribute('data-open', '');
    } else if (d.type === '__deactivate_edit_mode') {
      if (panel) panel.removeAttribute('data-open');
    }
  });

  try {
    window.parent.postMessage({ type: '__edit_mode_available' }, '*');
  } catch (e) {}
})();
</script>

