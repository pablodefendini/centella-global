  --radius-xs:   3px;       /* inline code, small chips */
  --radius-sm:   4px;       /* small panels, callouts, status tags */
  --radius-md:   6px;       /* cards, event cards, code blocks */
  --radius-lg:   8px;       /* buttons, inputs, medium panels */
  --radius-xl:   12px;      /* large surfaces */
  --radius-2xl:  16px;      /* large panels */
