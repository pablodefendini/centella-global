}
h6 {
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: var(--text-base);
  line-height: var(--leading-tight);
  letter-spacing: -0.01em;
}

/* ============================================================
   DISPLAY TYPE — signature hero treatment
   .display        : Barlow Condensed 300 (light), fluid size
   .display__accent: inline span, weight 800, gradient clipped to glyphs
   The 300 ↔ 800 contrast is the signature — don't approximate
   with 500/700.
   ============================================================ */
.display {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(3rem, 9vw, 6rem);
  line-height: 0.92;
  letter-spacing: -0.03em;
}

.display__accent,
.display--gradient {
  font-weight: 800;
  color: transparent;
  -webkit-text-fill-color: transparent;
  -webkit-background-clip: text;
  background-clip: text;
  background-color: transparent;
  /* Use background-image (not shorthand) so clip: text isn't reset. */
  background-image: var(--grad-violet-coral);
  background-repeat: no-repeat;
}
.display__accent--violet-coral { background-image: var(--grad-violet-coral); }
.display__accent--cyan-lime    { background-image: var(--grad-cyan-lime); }
.display__accent--coral-orange { background-image: var(--grad-coral-orange); }
.display__accent--pink-violet  { background-image: var(--grad-pink-violet); }
.display__accent--cyan-violet  { background-image: var(--grad-cyan-violet); }
.display__accent--lime-teal    { background-image: var(--grad-lime-teal); }

/* Body */
p   { font-family: var(--font-body); font-weight: 400; line-height: var(--leading-normal); }
.lede,
.pull-quote {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: var(--text-xl);
  line-height: 1.5;
}

/* Eyebrows / labels / nav / buttons — Barlow Semi Condensed tracked out */
.eyebrow, .label, .nav-link {
  font-family: var(--font-semi);
  font-weight: 600;
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--color-text-muted);
}

/* Mono */
code, pre, .mono {
  font-family: var(--font-mono);
  font-size: 0.92em;
}
code {
  background: var(--bg-elevated);
  padding: 0.1em 0.4em;
  border-radius: var(--radius-sm);
  color: var(--investment);
}

/* ============================================================
   LINKS
   Base inline link uses the violet→coral contrast pattern.
   Inside .tone-surface, links inherit currentColor and use a
   tone-based hover (never switch to unrelated global accents).
   ============================================================ */
a {
  --inline-link-color:       var(--violet);
  --inline-link-hover-color: var(--networking);
  color: var(--inline-link-color);
  text-decoration: none;
  transition: color var(--transition-fast);
}
a:hover,
a:focus-visible { color: var(--inline-link-hover-color); }

.tone-surface a:not(.btn) {
  --inline-link-color: currentColor;
  --inline-link-hover-color: color-mix(in srgb, currentColor 82%, white);
}
.tone-surface a:not(.btn):hover,
.tone-surface a:not(.btn):focus-visible { color: var(--inline-link-hover-color); }

/* ============================================================
   DEPRECATED TOKEN ALIASES
   Legacy --accent-* names kept as aliases so old code keeps
   rendering. Do NOT use in new code. A full rename pass is
   planned — see design.md “Token vocabulary.”
   --accent-teal / --accent-green have NO canonical equivalent
   in the brand palette and are stale.
   ============================================================ */
:root {
  --accent-purple: var(--violet);
  --accent-coral:  var(--networking);
  --accent-lime:   var(--investment);
  --accent-cyan:   var(--advisory);
  --accent-orange: var(--global);
  --accent-pink:   var(--tech);
  --accent-teal:   #00A3B6;   /* stale — no canonical equivalent */
  --accent-green:  #6EA92B;   /* stale — no canonical equivalent */
}

::selection { background: rgba(199, 125, 255, 0.25); color: var(--color-text); }
