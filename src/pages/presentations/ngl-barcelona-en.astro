<script is:inline>
  // Suppress benign ResizeObserver loop notifications from the deck scaler.
  window.addEventListener('error', (e) => {
    if (e && e.message && e.message.indexOf('ResizeObserver loop') !== -1) {
      e.stopImmediatePropagation();
      e.preventDefault();
    }
  });
</script>
<script is:inline>
  // Ensure closing slide uses the same shared top header chrome.
  document.addEventListener('DOMContentLoaded', () => {
    const headlineGradients = [
      'linear-gradient(135deg, var(--violet), var(--networking))',
      'linear-gradient(135deg, var(--advisory), var(--investment))',
      'linear-gradient(135deg, var(--networking), var(--global))',
      'linear-gradient(135deg, var(--tech), var(--violet))',
      'linear-gradient(135deg, var(--advisory), var(--violet))',
      'linear-gradient(135deg, var(--investment), var(--advisory))'
    ];
    const headlineAccentSelector = [
      '.title b',
      '.title strong',
      '.title .grad',
      '.h2 b',
      '.h2 strong',
      '.section-header .h b',
      '.section-header .h strong',
      '.section-header .h .grad',
      '.cover__display .accent',
      '.cover__display b',
      '.cover__display strong',
      '.hero-title b',
      '.hero-title strong',
      '.quote-slide .q .grad',
      '.closing__q .grad'
    ].join(', ');
    const headlineAccents = document.querySelectorAll(headlineAccentSelector);
    headlineAccents.forEach((el, index) => {
      el.style.setProperty('--headline-grad', headlineGradients[index % headlineGradients.length]);
    });

    const closingSlide = document.querySelector('section.slide.closing');
    const sharedTopHeader = document.querySelector('section.slide:not(.cover) .chrome--top');
    if (!closingSlide || !sharedTopHeader) return;

    // "no-chrome" hides all chrome blocks; remove it for the closing slide.
    closingSlide.classList.remove('no-chrome');

    // Only inject if the closing slide doesn't already have a top chrome block.
    if (!closingSlide.querySelector('.chrome--top')) {
      const clonedHeader = sharedTopHeader.cloneNode(true);
      const pg = clonedHeader.querySelector('.pg');
      if (pg) pg.textContent = '15 / 15';
      closingSlide.prepend(clonedHeader);
    }
  });
</script>


