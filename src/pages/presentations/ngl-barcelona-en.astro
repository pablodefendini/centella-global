  --color-border:     rgba(247, 237, 255, 0.08);

  /* ========= COLOR: Semantic state ========= */
  --success: var(--investment);   /* #CCFF00 */
  --error:   var(--networking);   /* #FF6B6B */
  --warning: var(--global);       /* #FF9500 */
  --info:    var(--advisory);     /* #00E5FF */

  /* ========= COLOR: Approved gradients (web only — never on logo) ========= */
  --grad-violet-coral:    linear-gradient(135deg, var(--violet),     var(--networking));
  --grad-cyan-lime:       linear-gradient(135deg, var(--advisory),   var(--investment));
  --grad-coral-orange:    linear-gradient(135deg, var(--networking), var(--global));
  --grad-pink-violet:     linear-gradient(135deg, var(--tech),       var(--violet));
  --grad-cyan-violet:     linear-gradient(135deg, var(--advisory),   var(--violet));
  --grad-lime-teal:       linear-gradient(135deg, var(--investment), var(--advisory));

  /* ========= TYPE: Families ========= */
  /* One family, many voices — the Barlow superfamily does all the work. */
  --font-display: 'Barlow Condensed', system-ui, sans-serif;        /* headlines, posters, section headers */
  --font-heading: 'Barlow', system-ui, sans-serif;                  /* card titles, sub-headlines */
  --font-semi:    'Barlow Semi Condensed', system-ui, sans-serif;   /* labels, nav, buttons, eyebrows */
  --font-body:    'Barlow', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  --font-mono:    'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;

  /* ========= TYPE: Scale ========= */
  --text-xs:   0.65rem;
  --text-sm:   0.806rem;
  --text-base: 1rem;
  --text-lg:   1.24rem;
  --text-xl:   1.538rem;
  --text-2xl:  1.907rem;
  --text-3xl:  2.364rem;
  --text-4xl:  2.931rem;
  --text-5xl:  3.634rem;
  --text-6xl:  4.507rem;

  /* ========= TYPE: Line heights ========= */
  --leading-tight:   1.15;   /* headings */
  --leading-normal:  1.6;    /* body default */
  --leading-relaxed: 1.75;   /* long-form reading */

  /* ========= SPACE: 4px base ========= */
  --space-1:  0.25rem;    /* 4  — xs */
  --space-2:  0.5rem;     /* 8  — sm */
  --space-3:  0.75rem;    /* 12 */
  --space-4:  1rem;       /* 16 — md */
  --space-6:  1.5rem;     /* 24 — lg */
  --space-8:  2rem;       /* 32 — xl */
  --space-12: 3rem;       /* 48 — 2xl */
  --space-16: 4rem;       /* 64 — 3xl */
  --space-24: 6rem;       /* 96 — 4xl */
  --space-32: 8rem;       /* 128 — 5xl */

  /* ========= LAYOUT ========= */
  --max-width:        72rem;   /* 1152 */
  --max-width-narrow: 48rem;   /* 768 */
  --gutter:           var(--space-4);            /* widens to --space-6 (24px) ≥640px */
  --touch-target-min: 2.75rem;                   /* WCAG ~44×44 */
  --prose-max-ch:     60ch;
  /* ========= RADIUS =========
