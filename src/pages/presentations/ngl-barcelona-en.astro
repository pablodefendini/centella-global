  --advisory-dark:  #0E2228;
  --advisory-light: #E1FCFF;

  /* Networking — mobilization & power */
  --networking:       #FF6B6B;
  --networking-dark:  #22181C;
  --networking-light: #FFE8E8;

  /* Investment — capital & impact */
  --investment:       #CCFF00;
  --investment-dark:  #1E2413;
  --investment-light: #FAFFE6;

  /* ========= COLOR: Theme colors ========= */
  --global:       #FF9500;
  --global-dark:  #301C00;
  --global-light: #FFF3E1;

  --tech:       #FF66C4;
  --tech-dark:  #2A1522;
  --tech-light: #FFE6F5;

  /* ========= COLOR: Surface & text (semantic) ========= */
  --bg-deep:     var(--violet-dark);   /* page background (default) */
  --bg-primary:  #080809;   /* section background */
  --bg-surface:  #0D0D0F;   /* card background */
  --bg-elevated: #151517;   /* input fields, elevated elements */
  --bg-lavender: #F7EDFF;   /* light inverse surface */

  --color-text:       #F7EDFF;
  --color-text-muted: rgba(247, 237, 255, 0.6);
