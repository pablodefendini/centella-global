---
import Base from '../../layouts/Base.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getPublishedBlogPosts } from '../../lib/notion';

const posts = await getPublishedBlogPosts();
---

<Base title="Blog" description="Writing and updates from Centella.">
  <section class="section">
    <div class="container">
      <h1 class="page-heading">Blog</h1>
      <p class="page-intro text-muted">Writing and updates from Centella.</p>
      {posts.length > 0 ? (
        <div class="blog-grid grid grid--2">
          {posts.map((post) => (
            <BlogPostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-muted" style="margin-top: var(--space-8);">
          No posts published yet. Check back soon.
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-grid {
    margin-top: 0;
  }
</style>
