---
import Base from '../../layouts/Base.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getPublishedBlogPosts } from '../../lib/notion';

const posts = await getPublishedBlogPosts();
---

<Base title="Blog" description="Writing and updates from Centella.">
  <section class="section">
    <div class="container">
      <h1>Blog</h1>
      {posts.length > 0 ? (
        <div class="grid grid--2" style="margin-top: var(--space-8);">
          {posts.map((post) => (
            <BlogPostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-muted" style="margin-top: var(--space-8);">
          No posts published yet. Check back soon.
        </p>
      )}
    </div>
  </section>
</Base>

<style>
  h1 {
    margin-bottom: var(--space-8);
  }
</style>
