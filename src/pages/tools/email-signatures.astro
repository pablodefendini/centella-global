---
/**
 * /tools/email-signatures — generate a transparent PNG signature for every
 * Active team member.
 *
 * The actual PNGs are generated at build time by scripts/build-team-assets.mjs
 * and live at /tools/email-signatures/<slug>.png — co-located with this page so
 * the whole staff section (page + assets) sits under a single /tools prefix.
 * Both are gated by src/middleware.ts.
 *
 * `prerender = false` is required: see src/pages/tools/index.astro for the
 * explanation.
 */
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { getTeamProfiles } from '../../lib/notion';

const profiles = await getTeamProfiles();
---

<Base
  title="Email signatures"
  description="Transparent-PNG email signatures for Centella staff and contractors."
>
  <section class="section">
    <div class="container page-simple">
      <p class="eyebrow"><a href="/tools" class="eyebrow__link">← Tools</a></p>
      <h1 class="page-heading">Email signatures</h1>
      <p class="page-copy">
        Transparent PNG at 2&times; density. Drop it into your mail client&rsquo;s signature
        field. Works in Gmail, Apple Mail, Outlook, Spark &mdash; anywhere that accepts an
        inline image. Regenerated from your Notion profile on every site deploy.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {profiles.length === 0 ? (
        <p class="empty">
          No active team profiles found in Notion yet. Add some to the Team Profiles database
          (with Status = Active) and redeploy.
        </p>
      ) : (
        <ul class="people">
          {profiles.map((person) => (
            <li class="person">
              <div class="person__id">
                <p class="person__name">{person.name}</p>
                {person.title && <p class="person__role">{person.title}</p>}
              </div>
              <a
                class="btn btn--secondary"
                href={`/tools/email-signatures/${person.slug}.png`}
                download
              >
                Download PNG
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container page-simple">
      <h2 class="page-subheading">Installing in your mail client</h2>
      <details class="install">
        <summary>Gmail (web)</summary>
        <ol>
          <li>Open Gmail Settings &rarr; <em>See all settings</em> &rarr; General.</li>
          <li>Scroll to <em>Signature</em>. Create a new signature.</li>
          <li>In the editor, click the image icon and upload the PNG you just downloaded.</li>
          <li>Set it as default for new mails and replies. Save.</li>
        </ol>
      </details>
      <details class="install">
        <summary>Apple Mail (macOS)</summary>
        <ol>
          <li>Mail &rarr; Settings &rarr; Signatures.</li>
          <li>Pick the account, hit <em>+</em>, drag the PNG into the signature pane.</li>
          <li>Make sure <em>Always match my default message font</em> is unchecked or the image scales weirdly.</li>
        </ol>
      </details>
      <details class="install">
        <summary>Outlook (web + desktop)</summary>
        <ol>
          <li>Settings &rarr; Mail &rarr; Compose and reply &rarr; Email signature.</li>
          <li>Use the image button in the toolbar to upload the PNG.</li>
          <li>Pick which mails the signature attaches to (new, reply, both).</li>
        </ol>
      </details>
    </div>
  </section>
</Base>

<style>
  .eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .eyebrow__link {
    color: inherit;
    text-decoration: none;
  }

  .eyebrow__link:hover { color: var(--color-accent); }

  .empty {
    color: var(--color-text-muted);
    text-align: center;
    padding-block: var(--space-12);
  }

  .people {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }

  .person {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    background: var(--bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }

  .person__id { min-width: 0; }

  .person__name {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-lg);
  }

  .person__role {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .page-subheading {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-4);
  }

  .install {
    background: var(--bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-4) var(--space-6);
  }

  .install summary {
    font-family: var(--font-heading);
    font-weight: 500;
    cursor: pointer;
  }

  .install ol {
    margin-top: var(--space-3);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
</style>
