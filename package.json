    "pdfkit": "^0.18.0",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@vercel/node": "^5.0.0",
    "typescript": "^5.7.0"
