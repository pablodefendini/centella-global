{
  "name": "centella-global",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/build-team-assets.mjs && node scripts/copy-share.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "media:hero": "bash scripts/optimize-hero-media.sh",
